@{
    ViewData["Title"] = "Home";
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,600;0,700;1,400&family=DM+Sans:wght@300;400;500;600;700&display=swap');

    :root {
        --red: #c0392b;
        --red-dark: #922b21;
        --red-light: #e74c3c;
        --blue: #1a3a6b;
        --blue-mid: #1d4ed8;
        --blue-light: #3b82f6;
        --blue-pale: #93c5fd;
        --white: #ffffff;
        --off-white: #f0f4f8;
        --ink: #0d1b2a;
    }

    /* ═══ HERO ═══ */
    .hm-hero { position:relative; width:100vw; margin-left:calc(-50vw + 50%); height:100vh; min-height:600px; overflow:hidden; display:flex; align-items:center; justify-content:center; }
    .hm-hero-slideshow { position:absolute; inset:0; z-index:0; }
    .hm-hero-slide { position:absolute; inset:0; background-size:cover; background-position:center; opacity:0; transition:opacity 1.2s ease; }
    .hm-hero-slide.active { opacity:1; }
    .hm-hero-overlay { position:absolute; inset:0; z-index:1; background:linear-gradient(135deg,rgba(26,58,107,.52) 0%,rgba(192,57,43,.22) 50%,rgba(26,58,107,.58) 100%); }
    .hm-hero-vignette { position:absolute; inset:0; z-index:1; background:radial-gradient(ellipse at center,transparent 40%,rgba(10,20,50,.18) 100%); }
    .hm-hero-stripe { position:absolute; top:0; left:0; width:7px; height:100%; background:linear-gradient(to bottom,var(--red),var(--red-dark)); z-index:3; }
    .hm-hero-content { position:relative; z-index:3; text-align:center; padding:0 2rem 5rem; max-width:900px; width:100%; }
    .hm-hero-prelabel { display:inline-flex; align-items:center; gap:.75rem; font-family:'DM Sans',sans-serif; font-size:11px; font-weight:600; letter-spacing:3.5px; text-transform:uppercase; color:#fca5a5; margin-bottom:1.75rem; opacity:0; animation:fadeSlideUp .9s ease .2s forwards; }
    .hm-hero-prelabel::before,.hm-hero-prelabel::after { content:''; display:block; width:28px; height:1px; background:#fca5a5; opacity:.8; }
    .hm-hero-title { font-family:'Cormorant Garamond',Georgia,serif; font-size:clamp(2.8rem,4vw,5.2rem); font-weight:700; color:#fff; line-height:1.05; letter-spacing:-1px; margin:0 0 .5rem; opacity:0; animation:fadeSlideUp 1s ease .4s forwards; text-shadow:0 2px 20px rgba(0,0,0,.5),0 4px 40px rgba(0,0,0,.3); }
    .hm-hero-divider { width:60px; height:3px; background:linear-gradient(to right,var(--red),var(--blue-light)); margin:1.75rem auto; opacity:0; animation:fadeSlideUp 1s ease .6s forwards; }
    .hm-hero-tagline { font-family:'DM Sans',sans-serif; font-size:clamp(1rem,2vw,1.2rem); font-weight:300; color:rgba(255,255,255,.93); line-height:1.7; max-width:600px; margin:0 auto 2.5rem; opacity:0; animation:fadeSlideUp 1s ease .8s forwards; text-shadow:0 1px 12px rgba(0,0,0,.4); }
    .hm-hero-tagline strong { color:#fff; font-weight:600; }
    .hm-hero-ctas { display:flex; align-items:center; justify-content:center; gap:1rem; flex-wrap:wrap; opacity:0; animation:fadeSlideUp 1s ease 1s forwards; }
    .hm-btn-primary { display:inline-flex; align-items:center; gap:.5rem; background:var(--red); color:#fff; font-family:'DM Sans',sans-serif; font-size:.875rem; font-weight:600; padding:.85rem 2rem; border-radius:8px; text-decoration:none; transition:background .2s,transform .15s,box-shadow .2s; box-shadow:0 4px 20px rgba(192,57,43,.45); }
    .hm-btn-primary:hover { background:var(--red-dark); color:#fff; transform:translateY(-2px); box-shadow:0 8px 28px rgba(192,57,43,.55); text-decoration:none; }
    .hm-btn-ghost { display:inline-flex; align-items:center; gap:.5rem; background:transparent; color:#fff; font-family:'DM Sans',sans-serif; font-size:.875rem; font-weight:600; padding:.85rem 2rem; border-radius:8px; border:1.5px solid rgba(255,255,255,.5); text-decoration:none; transition:background .2s,border-color .2s,transform .15s; }
    .hm-btn-ghost:hover { background:rgba(255,255,255,.12); border-color:rgba(255,255,255,.8); color:#fff; transform:translateY(-2px); text-decoration:none; }
    .hm-hero-stats { position:absolute; bottom:0; left:0; right:0; z-index:4; background:rgba(26,58,107,.88); backdrop-filter:blur(12px); border-top:3px solid var(--red); padding:1.1rem 2rem; display:flex; justify-content:center; opacity:0; animation:fadeIn .8s ease 1.6s forwards; }
    .hm-stat-item { display:flex; flex-direction:column; align-items:center; padding:0 3rem; border-right:1px solid rgba(255,255,255,.15); }
    .hm-stat-item:last-child { border-right:none; }
    .hm-stat-num { font-family:'Cormorant Garamond',serif; font-size:1.8rem; font-weight:700; color:#fff; line-height:1; }
    .hm-stat-label { font-family:'DM Sans',sans-serif; font-size:10px; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; color:rgba(255,255,255,.55); margin-top:.3rem; }
    @@keyframes fadeSlideUp { from{opacity:0;transform:translateY(22px)} to{opacity:1;transform:translateY(0)} }
    @@keyframes fadeIn { from{opacity:0} to{opacity:1} }
    @@media(max-width:768px){ .hm-hero{min-height:100svh} .hm-stat-item{padding:0 1.25rem} .hm-stat-num{font-size:1.4rem} }
    @@media(max-width:480px){ .hm-hero-stats{display:grid;grid-template-columns:repeat(2,1fr)} .hm-stat-item{border-right:none;border-bottom:1px solid rgba(255,255,255,.1);padding:.6rem} .hm-stat-item:nth-child(3),.hm-stat-item:nth-child(4){border-bottom:none} }

    /* ═══ PURPOSE ═══ */
    .pur { position:relative; width:100vw; margin-left:calc(-50vw + 50%); background:var(--off-white); padding:0 0 6rem; overflow:hidden; font-family:'DM Sans',sans-serif; }
    .pur::before { content:''; display:block; height:4px; background:linear-gradient(90deg,var(--red) 0%,var(--blue-mid) 100%); }
    .pur-watermark { position:absolute; top:-2rem; right:-1.5rem; font-family:'Cormorant Garamond',serif; font-size:clamp(14rem,22vw,22rem); font-weight:700; color:rgba(26,58,107,.045); line-height:1; pointer-events:none; user-select:none; letter-spacing:-12px; z-index:0; }
    .pur-header { position:relative; z-index:1; display:grid; grid-template-columns:1fr auto; align-items:end; gap:2rem; max-width:1180px; margin:0 auto; padding:4.5rem 2.5rem 3rem; }
    .pur-eyebrow { display:inline-flex; align-items:center; gap:.65rem; font-size:10px; font-weight:700; letter-spacing:3.5px; text-transform:uppercase; color:var(--red); margin-bottom:1rem; }
    .pur-eyebrow::before { content:''; display:block; width:28px; height:2px; background:var(--red); }
    .pur-title { font-family:'Cormorant Garamond',serif; font-size:clamp(2rem,3.5vw,3.2rem); font-weight:700; color:var(--ink); line-height:1.12; letter-spacing:-.5px; max-width:600px; }
    .pur-title em { font-style:italic; font-weight:300; color:var(--blue); }
    .pur-header-right { display:flex; flex-direction:column; align-items:flex-end; gap:1rem; padding-bottom:.25rem; }
    .pur-sub { font-size:.82rem; line-height:1.7; color:#5a6a80; max-width:280px; text-align:right; }
    .pur-learn { display:inline-flex; align-items:center; gap:.55rem; font-size:.75rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#fff; background:var(--blue); padding:.75rem 1.75rem; border-radius:4px; text-decoration:none; transition:background .2s,transform .2s,box-shadow .2s; box-shadow:0 4px 18px rgba(26,58,107,.22); }
    .pur-learn:hover { background:var(--red); color:#fff; transform:translateY(-2px); box-shadow:0 8px 24px rgba(192,57,43,.3); text-decoration:none; }
    .pur-learn svg { transition:transform .2s; }
    .pur-learn:hover svg { transform:translateX(3px); }
    .pur-grid { position:relative; z-index:1; max-width:1180px; margin:0 auto; padding:0 2.5rem; display:grid; grid-template-columns:1.55fr 1fr 1fr; grid-template-rows:auto auto; gap:1rem; }
    .pur-card { position:relative; overflow:hidden; border-radius:16px; text-decoration:none; display:flex; flex-direction:column; justify-content:flex-end; cursor:pointer; background:#dde3ed; transition:transform .35s cubic-bezier(.22,.68,0,1.2),box-shadow .35s ease; box-shadow:0 2px 16px rgba(0,0,0,.08); }
    .pur-card:hover { transform:translateY(-5px) scale(1.012); box-shadow:0 20px 52px rgba(0,0,0,.17); text-decoration:none; }
    .pur-card-img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; object-position:center; transition:transform .55s ease; }
    .pur-card:hover .pur-card-img { transform:scale(1.07); }
    .pur-card-scrim { position:absolute; inset:0; background:linear-gradient(to top,rgba(13,27,42,.92) 0%,rgba(13,27,42,.45) 45%,rgba(13,27,42,0) 100%); transition:background .35s ease; }
    .pur-card:hover .pur-card-scrim { background:linear-gradient(to top,rgba(192,57,43,.90) 0%,rgba(192,57,43,.50) 48%,rgba(192,57,43,0) 100%); }
    .pur-card::after { content:''; position:absolute; bottom:0; left:0; right:0; height:3px; background:var(--red); transform:scaleX(0); transform-origin:left; transition:transform .3s ease; }
    .pur-card:hover::after { transform:scaleX(1); }
    .pur-card-body { position:relative; z-index:2; padding:1.5rem 1.4rem 1.6rem; }
    .pur-card-num { font-family:'Cormorant Garamond',serif; font-size:.7rem; font-weight:600; letter-spacing:2px; color:rgba(255,255,255,.4); margin-bottom:.65rem; }
    .pur-card-title { font-size:.78rem; font-weight:700; letter-spacing:1.8px; text-transform:uppercase; color:#fca5a5; margin-bottom:.45rem; transition:color .2s; }
    .pur-card:hover .pur-card-title { color:#fff; }
    .pur-card-desc { font-size:.77rem; color:rgba(255,255,255,.72); line-height:1.6; max-height:0; overflow:hidden; transition:max-height .35s ease,opacity .3s ease; opacity:0; }
    .pur-card:hover .pur-card-desc { max-height:60px; opacity:1; }
    .pur-card-cta { display:inline-flex; align-items:center; gap:.35rem; font-size:.68rem; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#fff; margin-top:.9rem; opacity:0; transform:translateY(6px); transition:opacity .25s ease .05s,transform .25s ease .05s; }
    .pur-card:hover .pur-card-cta { opacity:1; transform:translateY(0); }
    .pur-card--feature { grid-column:1; grid-row:1/3; height:560px; }
    .pur-card--feature .pur-card-title { font-family:'Cormorant Garamond',serif; font-size:1.45rem; font-weight:700; letter-spacing:0; text-transform:none; color:#fff; line-height:1.25; }
    .pur-card--feature .pur-card-num { font-size:.8rem; color:rgba(255,255,255,.35); }
    .pur-card--feature .pur-card-desc { max-height:0; }
    .pur-card--feature:hover .pur-card-desc { max-height:80px; }
    .pur-card--feature .pur-card-body { padding:2rem 1.8rem 2.2rem; }
    .pur-feature-tag { position:absolute; top:1.25rem; left:1.25rem; z-index:3; background:var(--red); color:#fff; font-size:9px; font-weight:700; letter-spacing:2px; text-transform:uppercase; padding:.3rem .8rem; border-radius:50px; }
    .pur-card--sm { height:270px; }
    .pur-card--strip { grid-column:2/4; grid-row:2; height:270px; flex-direction:row; align-items:flex-end; justify-content:flex-start; }
    .pur-card--strip .pur-card-scrim { background:linear-gradient(to right,rgba(13,27,42,.94) 0%,rgba(13,27,42,.5) 55%,rgba(13,27,42,0) 100%); }
    .pur-card--strip:hover .pur-card-scrim { background:linear-gradient(to right,rgba(192,57,43,.92) 0%,rgba(192,57,43,.5) 55%,rgba(192,57,43,0) 100%); }
    .pur-card--strip .pur-card-body { padding:1.8rem 2rem; max-width:340px; }
    @@media(max-width:900px){ .pur-grid{grid-template-columns:1fr 1fr;grid-template-rows:auto} .pur-card--feature{grid-column:1/3;grid-row:auto;height:320px} .pur-card--strip{grid-column:1/3;grid-row:auto} .pur-card--sm{height:230px} }
    @@media(max-width:700px){ .pur-header{grid-template-columns:1fr;padding:3.5rem 1.5rem 2.5rem} .pur-header-right{align-items:flex-start} .pur-sub{text-align:left} .pur-grid{padding:0 1.5rem} }
    @@media(max-width:480px){ .pur-grid{grid-template-columns:1fr} .pur-card--feature{grid-column:1;height:280px} .pur-card--strip{grid-column:1;height:220px} .pur-card--sm{height:200px} }

    /* ═══ COMPANY PROFILE (HOME) ═══ */
    .hm-cp { position:relative; width:100vw; margin-left:calc(-50vw + 50%); background:#fff; padding:0 0 6rem; overflow:hidden; font-family:'DM Sans',sans-serif; }
    .hm-cp::before { content:''; display:block; height:4px; background:linear-gradient(90deg,var(--blue) 0%,var(--red) 100%); }
    .hm-cp-watermark { position:absolute; top:-1rem; left:-2rem; font-family:'Cormorant Garamond',serif; font-size:clamp(12rem,18vw,20rem); font-weight:700; color:rgba(26,58,107,.03); line-height:1; pointer-events:none; user-select:none; letter-spacing:-10px; z-index:0; }
    .hm-cp-inner { position:relative; z-index:1; max-width:1180px; margin:0 auto; padding:4.5rem 2.5rem 0; }
    .hm-cp-header { display:grid; grid-template-columns:1fr auto; align-items:end; gap:2rem; margin-bottom:3.5rem; }
    .hm-cp-eyebrow { display:inline-flex; align-items:center; gap:.65rem; font-size:10px; font-weight:700; letter-spacing:3.5px; text-transform:uppercase; color:var(--blue); margin-bottom:.85rem; }
    .hm-cp-eyebrow::before { content:''; display:block; width:28px; height:2px; background:var(--blue); }
    .hm-cp-title { font-family:'Cormorant Garamond',serif; font-size:clamp(2rem,3.5vw,3.2rem); font-weight:700; color:var(--ink); line-height:1.12; letter-spacing:-.5px; }
    .hm-cp-title em { font-style:italic; font-weight:300; color:var(--red); }
    .hm-cp-header-right { display:flex; flex-direction:column; align-items:flex-end; gap:1rem; }
    .hm-cp-header-sub { font-size:.82rem; line-height:1.7; color:#5a6a80; max-width:260px; text-align:right; }
    .hm-cp-header-link { display:inline-flex; align-items:center; gap:.55rem; font-size:.75rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:#fff; background:var(--red); padding:.75rem 1.75rem; border-radius:4px; text-decoration:none; white-space:nowrap; transition:background .2s,transform .2s,box-shadow .2s; box-shadow:0 4px 18px rgba(192,57,43,.25); }
    .hm-cp-header-link:hover { background:var(--red-dark); color:#fff; transform:translateY(-2px); box-shadow:0 8px 24px rgba(192,57,43,.4); text-decoration:none; }
    .hm-cp-header-link svg { transition:transform .2s; }
    .hm-cp-header-link:hover svg { transform:translateX(3px); }

    /* Main 2-col layout */
    .hm-cp-layout { display:grid; grid-template-columns:1.1fr .9fr; gap:3.5rem; align-items:start; }

    /* LEFT: video + stats */
    .hm-cp-media { display:flex; flex-direction:column; gap:1.25rem; }
    .hm-cp-video-wrap { position:relative; border-radius:18px; overflow:hidden; box-shadow:0 16px 50px rgba(0,0,0,.14); }
    .hm-cp-video-wrap::before { content:''; position:absolute; bottom:0; left:0; right:0; height:50%; background:linear-gradient(to top,rgba(13,27,42,.55),transparent); z-index:1; pointer-events:none; }
    .hm-cp-video-wrap video { width:100%; display:block; aspect-ratio:16/10; object-fit:cover; }
    .hm-cp-video-label { position:absolute; bottom:1rem; left:1.25rem; z-index:2; display:flex; align-items:center; gap:.55rem; font-family:'DM Sans',sans-serif; font-size:11px; font-weight:600; letter-spacing:1.5px; text-transform:uppercase; color:rgba(255,255,255,.75); }
    .hm-cp-video-label::before { content:''; display:block; width:8px; height:8px; border-radius:50%; background:var(--red); animation:live-blink 1.5s ease-in-out infinite; }
    @@keyframes live-blink { 0%,100%{opacity:1} 50%{opacity:.2} }
    .hm-cp-stats-strip { display:grid; grid-template-columns:repeat(3,1fr); border:1px solid #e2e8f0; border-radius:14px; overflow:hidden; background:var(--off-white); }
    .hm-cp-stat { display:flex; flex-direction:column; align-items:center; justify-content:center; padding:1.35rem 1rem; border-right:1px solid #e2e8f0; transition:background .2s; }
    .hm-cp-stat:last-child { border-right:none; }
    .hm-cp-stat:hover { background:#fff; }
    .hm-cp-stat-num { font-family:'Cormorant Garamond',serif; font-size:2rem; font-weight:700; color:var(--blue); line-height:1; }
    .hm-cp-stat-label { font-size:9px; font-weight:700; letter-spacing:1.5px; text-transform:uppercase; color:#94a3b8; margin-top:.3rem; text-align:center; }

    /* RIGHT: text */
    .hm-cp-text { display:flex; flex-direction:column; }
    .hm-cp-lead { font-size:1.05rem; font-weight:700; color:var(--ink); line-height:1.45; margin-bottom:1.4rem; border-left:4px solid var(--red); padding-left:1rem; }
    .hm-cp-body { font-size:.9rem; color:#4b5563; line-height:1.85; margin-bottom:1rem; }
    .hm-cp-divider { border:none; border-top:1px solid #e5e7eb; margin:1.25rem 0; }
    .hm-cp-reg-badge { display:inline-flex; align-items:center; gap:.65rem; background:var(--off-white); border:1px solid #e2e8f0; border-radius:10px; padding:.8rem 1.1rem; font-size:.82rem; color:#4b5563; line-height:1.5; margin-bottom:1.5rem; }
    .hm-cp-reg-badge-icon { width:36px; height:36px; border-radius:8px; background:var(--blue); color:#fff; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-size:16px; }
    .hm-cp-reg-badge strong { color:var(--ink); display:block; font-size:.85rem; }
    .hm-cp-tags-label { font-size:10px; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:var(--blue); margin-bottom:.75rem; }
    .hm-cp-tags { display:flex; flex-wrap:wrap; gap:.45rem; margin-bottom:1.5rem; }
    .hm-cp-tag { background:#eff6ff; color:var(--red); border:1px solid rgba(192,57,43,.25); border-radius:6px; font-size:11px; font-weight:600; padding:.3rem .7rem; letter-spacing:.2px; transition:background .2s,border-color .2s; }
    .hm-cp-tag:hover { background:rgba(192,57,43,.06); border-color:var(--red); }

    /* Directors teaser */
    .hm-cp-directors { margin-top:4rem; padding-top:3.5rem; border-top:1px solid #e2e8f0; }
    .hm-cp-dir-header { display:flex; justify-content:space-between; align-items:flex-end; margin-bottom:2.5rem; }
    .hm-cp-dir-eyebrow { font-size:10px; font-weight:700; letter-spacing:3px; text-transform:uppercase; color:var(--red); margin-bottom:.5rem; display:flex; align-items:center; gap:.65rem; }
    .hm-cp-dir-eyebrow::before { content:''; display:block; width:28px; height:2px; background:var(--red); }
    .hm-cp-dir-title { font-family:'Cormorant Garamond',serif; font-size:clamp(1.6rem,2.5vw,2.2rem); font-weight:700; color:var(--ink); line-height:1.15; letter-spacing:-.3px; }
    .hm-cp-dir-title em { font-style:italic; font-weight:300; color:var(--blue); }
    .hm-cp-dir-link { display:inline-flex; align-items:center; gap:.55rem; font-size:.72rem; font-weight:700; letter-spacing:2px; text-transform:uppercase; color:var(--blue); text-decoration:none; border-bottom:2px solid transparent; transition:color .2s,border-color .2s; padding-bottom:2px; white-space:nowrap; }
    .hm-cp-dir-link:hover { color:var(--red); border-color:var(--red); text-decoration:none; }
    .hm-cp-dir-grid { display:grid; grid-template-columns:1fr 1fr; gap:2rem; }
    .hm-cp-dir-card { display:grid; grid-template-columns:120px 1fr; gap:1.5rem; align-items:start; border:1px solid #e2e8f0; border-radius:16px; padding:1.5rem; background:#fff; transition:box-shadow .3s ease,transform .3s ease; position:relative; overflow:hidden; }
    .hm-cp-dir-card::before { content:''; position:absolute; top:0; left:0; right:0; height:3px; background:linear-gradient(to right,var(--red),var(--blue-mid)); }
    .hm-cp-dir-card:hover { box-shadow:0 12px 40px rgba(0,0,0,.1); transform:translateY(-4px); }
    .hm-cp-dir-img-wrap { width:120px; height:148px; border-radius:12px; overflow:hidden; flex-shrink:0; box-shadow:0 4px 16px rgba(0,0,0,.12); }
    .hm-cp-dir-img-wrap img { width:100%; height:100%; object-fit:cover; object-position:top center; display:block; transition:transform .4s ease; }
    .hm-cp-dir-card:hover .hm-cp-dir-img-wrap img { transform:scale(1.05); }
    .hm-cp-dir-body { display:flex; flex-direction:column; gap:.3rem; }
    .hm-cp-dir-badge { display:inline-flex; align-items:center; gap:.4rem; background:#f0fdf4; border:1px solid #bbf7d0; color:#15803d; border-radius:999px; font-size:10px; font-weight:600; padding:.2rem .65rem; width:fit-content; margin-bottom:.5rem; }
    .hm-cp-dir-badge::before { content:"⚓"; font-size:11px; }
    .hm-cp-dir-name { font-size:1rem; font-weight:700; color:var(--ink); line-height:1.25; }
    .hm-cp-dir-role { font-size:10px; font-weight:700; letter-spacing:1.2px; text-transform:uppercase; color:var(--blue-mid); margin-bottom:.65rem; }
    .hm-cp-dir-bio { font-size:.8rem; color:#6b7280; line-height:1.7; display:-webkit-box; -webkit-line-clamp:4; -webkit-box-orient:vertical; overflow:hidden; }

    @@media(max-width:1000px){ .hm-cp-layout{grid-template-columns:1fr;gap:2.5rem} }
    @@media(max-width:768px){ .hm-cp-header{grid-template-columns:1fr} .hm-cp-header-right{align-items:flex-start} .hm-cp-header-sub{text-align:left} .hm-cp-inner{padding:3.5rem 1.5rem 0} .hm-cp-dir-grid{grid-template-columns:1fr;gap:1.5rem} .hm-cp-dir-header{flex-direction:column;align-items:flex-start;gap:1.25rem} }
