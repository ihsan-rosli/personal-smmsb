@{
    ViewData["Title"] = "MOSVA Membership Renewal 2026 — Synergy Marine (M) Sdn Bhd";
}

<style>
    /* ── HERO ── */
    .news-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        height: 380px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding-bottom: 2.5rem;
    }

    .news-hero-bg {
        position: absolute;
        inset: 0;
        background: url('/images/4.jpg') center center / cover no-repeat;
        filter: brightness(0.85);
        transform: scale(1.03);
        transition: transform 8s ease;
    }

    .news-hero:hover .news-hero-bg {
        transform: scale(1.0);
    }

    .news-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,20,50,0.2) 0%, rgba(10,20,50,0.78) 100%);
    }

    .news-hero-content {
        position: relative;
        z-index: 2;
        padding: 0 2rem;
        max-width: 1140px;
        margin: 0 auto;
        width: 100%;
    }

    .news-breadcrumb {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #60a5fa;
        margin-bottom: 0.75rem;
    }

        .news-breadcrumb a {
            color: #60a5fa;
            text-decoration: none;
        }

            .news-breadcrumb a:hover { text-decoration: underline; }

    .news-hero-title {
        font-size: clamp(1.6rem, 3.5vw, 2.6rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.2;
        margin: 0;
        max-width: 780px;
    }

    /* ── CONTENT WRAPPER ── */
    .news-content-wrapper {
        background: #f9fafb;
        border-radius: 16px 16px 0 0;
        margin-top: -2rem;
        position: relative;
        z-index: 3;
        box-shadow: 0 -4px 30px rgba(0,0,0,0.08);
        padding: 3rem 2rem 5rem;
        max-width: 1140px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    /* ── ARTICLE LAYOUT ── */
    .news-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 3rem;
        align-items: start;
    }

    /* ── ARTICLE MAIN ── */
    .news-article {
        background: #ffffff;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

    .news-feature-img-wrap {
        width: 100%;
        height: 420px;
        overflow: hidden;
        position: relative;
        background: #f1f5f9;
    }

    .news-feature-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        display: block;
        transition: transform 6s ease;
    }

    .news-article:hover .news-feature-img { transform: scale(1.02); }

    .news-img-tag {
        position: absolute;
        top: 1.25rem;
        left: 1.25rem;
        background: #0f766e;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0.35rem 0.85rem;
        border-radius: 20px;
    }

    .news-article-body { padding: 2rem 2.25rem 2.5rem; }

    .news-meta-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .news-meta-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: #64748b;
        font-weight: 500;
    }

    .news-meta-icon { font-size: 0.9rem; }

    .news-meta-divider {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: #cbd5e1;
    }

    .news-article-title {
        font-size: 1.45rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.35;
        margin-bottom: 1.5rem;
        letter-spacing: -0.3px;
    }

    .news-lead {
        font-size: 1rem;
        color: #374151;
        line-height: 1.85;
        font-weight: 500;
        margin-bottom: 1.5rem;
        padding: 1.1rem 1.4rem;
        background: #f0fdf4;
        border-left: 4px solid #16a34a;
        border-radius: 0 8px 8px 0;
        text-align: justify;
    }

    .news-body-text {
        font-size: 0.95rem;
        color: #4b5563;
        line-height: 1.9;
        margin-bottom: 1.25rem;
        text-align: justify;
    }

    /* Certificate highlight box */
    .news-cert-box {
        background: linear-gradient(135deg, #fffbeb, #fef3c7);
        border: 1px solid #fde68a;
        border-radius: 12px;
        padding: 1.5rem 1.75rem;
        margin: 1.75rem 0;
        display: flex;
        align-items: flex-start;
        gap: 1rem;
    }

    .news-cert-box-icon { font-size: 2rem; flex-shrink: 0; margin-top: 0.1rem; }

    .news-cert-box-title {
        font-size: 0.88rem;
        font-weight: 800;
        color: #92400e;
        margin-bottom: 0.4rem;
        letter-spacing: 0.2px;
    }

    .news-cert-box-detail {
        font-size: 0.82rem;
        color: #b45309;
        line-height: 1.6;
    }

    .news-caption {
        font-size: 0.78rem;
        color: #94a3b8;
        text-align: justify;
        margin-top: -0.5rem;
        margin-bottom: 1.75rem;
        font-style: italic;
    }

    .news-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
    }

    .news-tag {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        padding: 0.3rem 0.7rem;
        letter-spacing: 0.3px;
    }

    /* ── SIDEBAR ── */
    .news-sidebar {
        position: static;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .news-info-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
    }

    .news-info-card-header {
        background: linear-gradient(135deg, #0f2557, #1e40af);
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .news-info-card-header-title {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #fff;
    }

    .news-info-card-body { padding: 1.25rem; }

    .news-info-row {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.7rem 0;
        border-bottom: 1px solid #f8fafc;
    }

        .news-info-row:last-child { border-bottom: none; }

    .news-info-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #2563eb;
        flex-shrink: 0;
        margin-top: 5px;
    }

    .news-info-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 0.15rem;
    }

    .news-info-value {
        font-size: 0.83rem;
        color: #1e293b;
        font-weight: 500;
        line-height: 1.45;
    }

    .news-badge-card {
        background: linear-gradient(145deg, #f0fdf4, #dcfce7);
        border: 1px solid #86efac;
        border-radius: 14px;
        padding: 1.5rem;
        text-align: center;
    }

    .news-badge-icon {
        font-size: 2.5rem;
        margin-bottom: 0.6rem;
        display: block;
    }

    .news-badge-title {
        font-size: 0.88rem;
        font-weight: 800;
        color: #14532d;
        margin-bottom: 0.3rem;
        line-height: 1.3;
    }

    .news-badge-sub {
        font-size: 0.78rem;
        color: #16a34a;
        line-height: 1.5;
    }

    .news-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        color: #374151;
        font-size: 0.83rem;
        font-weight: 600;
        padding: 0.6rem 1.1rem;
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.15s, border-color 0.15s;
        width: 100%;
        justify-content: center;
    }

        .news-back-btn:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #374151;
            text-decoration: none;
        }

    @@media (max-width: 900px) {
        .news-layout { grid-template-columns: 1fr; }
        .news-feature-img-wrap { height: 280px; }
        .news-hero { height: 300px; }
        .news-article-body { padding: 1.5rem 1.25rem 2rem; }
    }

    @@media (max-width: 560px) {
        .news-content-wrapper { padding: 2rem 1.25rem 3.5rem; }
        .news-feature-img-wrap { height: 220px; }
        .news-article-title { font-size: 1.2rem; }
        .news-cert-box { flex-direction: column; gap: 0.6rem; }
    }
</style>

<!-- ── HERO ── -->
<div class="news-hero">
    <div class="news-hero-bg" style="background-image: url('/images/4.jpg');"></div>
    <div class="news-hero-overlay"></div>
    <div class="news-hero-content">
        <p class="news-breadcrumb">
            <a href="/News/News">News</a> &nbsp;/&nbsp; MOSVA Membership 2026
        </p>
        <h1 class="news-hero-title">Synergy Marine Renews MOSVA Membership for 2026</h1>
    </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="news-content-wrapper">
    <div class="news-layout">

        <!-- ── ARTICLE ── -->
        <article class="news-article">

            <!-- Feature Image -->
            <div class="news-feature-img-wrap">
                <img src="/images/news/mosva2026.jpg"
                     alt="MOSVA Certificate of Membership 2026 — Synergy Marine (M) Sdn Bhd, Membership No. OM050"
                     class="news-feature-img" />
                <span class="news-img-tag">🌊 Membership</span>
            </div>

            <div class="news-article-body">

                <!-- Meta -->
                <div class="news-meta-row">
                    <div class="news-meta-item">
                        <span class="news-meta-icon">📅</span>
                        <span>January 1, 2026</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">🏢</span>
                        <span>Industry Membership</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">🤝</span>
                        <span>MOSVA</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">🔖</span>
                        <span>Membership No. OM050</span>
                    </div>
                </div>

                <!-- Title -->
                <h2 class="news-article-title">
                    Synergy Marine (M) Sdn Bhd Renews Ordinary Membership with Malaysia OSV Owners' Association (MOSVA) for 2026
                </h2>

                <!-- Lead -->
                <p class="news-lead">
                    Synergy Marine (M) Sdn Bhd is pleased to confirm the renewal of its Ordinary Membership with the <strong>Malaysia OSV Owners' Association (MOSVA)</strong> for the year 2026, maintaining our continuous membership since 22nd May 2020 under Membership No. OM050.
                </p>

                <p class="news-body-text">
                    The Certificate of Membership, valid from 1st January 2026 to 31st December 2026 and signed by MOSVA President Jamalludin Bin Obeng, affirms Synergy Marine's continued standing as an Ordinary Member of this pivotal industry association representing Malaysia's Offshore Support Vessel (OSV) owners and operators.
                </p>

                <!-- Certificate Highlight Box -->
                <div class="news-cert-box">
                    <span class="news-cert-box-icon">📜</span>
                    <div>
                        <div class="news-cert-box-title">Certificate of Membership — MOSVA 2026</div>
                        <div class="news-cert-box-detail">
                            <strong>Member:</strong> Synergy Marine (M) Sdn Bhd &nbsp;|&nbsp; <strong>No.:</strong> OM050<br />
                            <strong>Status:</strong> Ordinary Member &nbsp;|&nbsp; <strong>Since:</strong> 22nd May 2020<br />
                            <strong>Validity:</strong> 1st January 2026 – 31st December 2026<br />
                            <strong>Signed by:</strong> Jamalludin Bin Obeng, President
                        </div>
                    </div>
                </div>

                <p class="news-body-text">
                    MOSVA plays a central role in representing the interests of Malaysian OSV operators at the national level, engaging with regulators, government bodies, and key industry stakeholders to advocate for a sustainable and competitive local OSV industry. As a member since 2020, Synergy Marine has actively participated in MOSVA-led forums, dialogues, and industry engagements — contributing to discussions on fleet renewal, decarbonisation, regulatory compliance, and the long-term development of Malaysia's offshore marine services sector.
                </p>

                <p class="news-body-text">
                    Our Managing Director, Yg Berbahagia Dato' Dr. Roslan Ahmad, serves as Vice President of MOSVA, further deepening Synergy Marine's commitment and contribution to the association's mission. Through this leadership role, Synergy Marine actively shapes the direction of industry advocacy, fostering collaboration among OSV owners and driving meaningful dialogue with authorities including the Marine Department of Malaysia (APMM) and other relevant bodies.
                </p>

                <p class="news-body-text">
                    The renewal of our MOSVA membership for 2026 reaffirms Synergy Marine's long-term dedication to the Malaysian maritime industry. We remain steadfast in our commitment to safe, reliable, and sustainable marine support services — and to being an active, responsible member of the OSV community in Malaysia.
                </p>

                <!-- Caption -->
                <p class="news-caption">
                    MOSVA Certificate of Membership 2026 issued to Synergy Marine (M) Sdn Bhd, confirming Ordinary Membership No. OM050 with validity from 1st January 2026 to 31st December 2026. | Source: Malaysia OSV Owners' Association (MOSVA).
                </p>

                <!-- Tags -->
                <div class="news-tags">
                    <span class="news-tag">MOSVA</span>
                    <span class="news-tag">Membership 2026</span>
                    <span class="news-tag">OSV</span>
                    <span class="news-tag">Synergy Marine</span>
                    <span class="news-tag">Malaysia Maritime</span>
                    <span class="news-tag">Industry Association</span>
                    <span class="news-tag">Offshore Support Vessel</span>
                    <span class="news-tag">OM050</span>
                    <span class="news-tag">Sustainability</span>
                    <span class="news-tag">Oil &amp; Gas</span>
                    <span class="news-tag">2026</span>
                </div>

            </div>
        </article>

        <!-- ── SIDEBAR ── -->
        <aside class="news-sidebar">

            <!-- Membership Badge -->
            <div class="news-badge-card">
                <span class="news-badge-icon">🌊</span>
                <div class="news-badge-title">MOSVA Ordinary Member 2026</div>
                <div class="news-badge-sub">Membership No. OM050<br />Member Since 22nd May 2020</div>
            </div>

            <!-- Membership Details -->
            <div class="news-info-card">
                <div class="news-info-card-header">
                    <span>📋</span>
                    <div class="news-info-card-header-title">Membership Details</div>
                </div>
                <div class="news-info-card-body">

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Organisation</div>
                            <div class="news-info-value">Malaysia OSV Owners' Association (MOSVA)</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Membership No.</div>
                            <div class="news-info-value">OM050</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Membership Type</div>
                            <div class="news-info-value">Ordinary Member</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Member Since</div>
                            <div class="news-info-value">22nd May 2020</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Validity Period</div>
                            <div class="news-info-value">
                                1 Jan 2026 – 31 Dec 2026
                            </div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Signed By</div>
                            <div class="news-info-value">
                                Jamalludin Bin Obeng<br />
                                <span style="color:#94a3b8; font-size:0.75rem;">President, MOSVA</span>
                            </div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Our Role in MOSVA</div>
                            <div class="news-info-value">
                                Dato' Dr. Roslan Ahmad<br />
                                <span style="color:#94a3b8; font-size:0.75rem;">Vice President, MOSVA</span>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Back button -->
            <a href="/News/News" class="news-back-btn">
                ← Back to News
            </a>

        </aside>
    </div>
</div>
