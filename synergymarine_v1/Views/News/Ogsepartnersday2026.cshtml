@{
    ViewData["Title"] = "PETRONAS OGSE Partners Day 2026 — Empowering Resilience";
}

<style>
    /* ── HERO ── */
    .news-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        height: 380px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding-bottom: 2.5rem;
    }

    .news-hero-bg {
        position: absolute;
        inset: 0;
        background: url('/images/4.jpg') center center / cover no-repeat;
        filter: brightness(0.85);
        transform: scale(1.03);
        transition: transform 8s ease;
    }

    .news-hero:hover .news-hero-bg {
        transform: scale(1.0);
    }

    .news-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,20,50,0.2) 0%, rgba(10,20,50,0.78) 100%);
    }

    .news-hero-content {
        position: relative;
        z-index: 2;
        padding: 0 2rem;
        max-width: 1140px;
        margin: 0 auto;
        width: 100%;
    }

    .news-breadcrumb {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #60a5fa;
        margin-bottom: 0.75rem;
    }

        .news-breadcrumb a {
            color: #60a5fa;
            text-decoration: none;
        }

            .news-breadcrumb a:hover {
                text-decoration: underline;
            }

    .news-hero-title {
        font-size: clamp(1.6rem, 3.5vw, 2.6rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.2;
        margin: 0;
        max-width: 780px;
    }

    /* ── CONTENT WRAPPER ── */
    .news-content-wrapper {
        background: #f9fafb;
        border-radius: 16px 16px 0 0;
        margin-top: -2rem;
        position: relative;
        z-index: 3;
        box-shadow: 0 -4px 30px rgba(0,0,0,0.08);
        padding: 3rem 2rem 5rem;
        max-width: 1140px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    /* ── ARTICLE LAYOUT ── */
    .news-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 3rem;
        align-items: start;
    }

    /* ── ARTICLE MAIN ── */
    .news-article {
        background: #ffffff;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

    .news-feature-img-wrap {
        width: 100%;
        height: 420px;
        overflow: hidden;
        position: relative;
        background: #f1f5f9;
    }

    .news-feature-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        display: block;
        transition: transform 6s ease;
    }

    .news-article:hover .news-feature-img {
        transform: scale(1.02);
    }

    .news-img-tag {
        position: absolute;
        top: 1.25rem;
        left: 1.25rem;
        background: #7c3aed;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0.35rem 0.85rem;
        border-radius: 20px;
    }

    .news-article-body {
        padding: 2rem 2.25rem 2.5rem;
    }

    .news-meta-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .news-meta-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: #64748b;
        font-weight: 500;
    }

    .news-meta-icon { font-size: 0.9rem; }

    .news-meta-divider {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: #cbd5e1;
    }

    .news-article-title {
        font-size: 1.45rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.35;
        margin-bottom: 1.5rem;
        letter-spacing: -0.3px;
    }

    .news-lead {
        font-size: 1rem;
        color: #374151;
        line-height: 1.85;
        font-weight: 500;
        margin-bottom: 1.5rem;
        padding: 1.1rem 1.4rem;
        background: #eff6ff;
        border-left: 4px solid #2563eb;
        border-radius: 0 8px 8px 0;
        text-align: justify;
    }

    .news-body-text {
        font-size: 0.95rem;
        color: #4b5563;
        line-height: 1.9;
        margin-bottom: 1.25rem;
        text-align: justify;
    }

    .news-caption {
        font-size: 0.78rem;
        color: #94a3b8;
        text-align: justify;
        margin-top: -0.5rem;
        margin-bottom: 1.75rem;
        font-style: italic;
    }

    .news-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
    }

    .news-tag {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        padding: 0.3rem 0.7rem;
        letter-spacing: 0.3px;
    }

    /* ── SIDEBAR ── */
    .news-sidebar {
        position: static;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .news-info-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
    }

    .news-info-card-header {
        background: linear-gradient(135deg, #0f2557, #1e40af);
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .news-info-card-header-title {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #fff;
    }

    .news-info-card-body { padding: 1.25rem; }

    .news-info-row {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.7rem 0;
        border-bottom: 1px solid #f8fafc;
    }

        .news-info-row:last-child { border-bottom: none; }

    .news-info-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #2563eb;
        flex-shrink: 0;
        margin-top: 5px;
    }

    .news-info-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 0.15rem;
    }

    .news-info-value {
        font-size: 0.83rem;
        color: #1e293b;
        font-weight: 500;
        line-height: 1.45;
    }

    .news-badge-card {
        background: linear-gradient(145deg, #f5f3ff, #ede9fe);
        border: 1px solid #c4b5fd;
        border-radius: 14px;
        padding: 1.5rem;
        text-align: center;
    }

    .news-badge-icon {
        font-size: 2.5rem;
        margin-bottom: 0.6rem;
        display: block;
    }

    .news-badge-title {
        font-size: 0.88rem;
        font-weight: 800;
        color: #4c1d95;
        margin-bottom: 0.3rem;
        line-height: 1.3;
    }

    .news-badge-sub {
        font-size: 0.78rem;
        color: #6d28d9;
        line-height: 1.5;
    }

    .news-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        color: #374151;
        font-size: 0.83rem;
        font-weight: 600;
        padding: 0.6rem 1.1rem;
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.15s, border-color 0.15s;
        width: 100%;
        justify-content: center;
    }

        .news-back-btn:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #374151;
            text-decoration: none;
        }

    @@media (max-width: 900px) {
        .news-layout { grid-template-columns: 1fr; }
        .news-feature-img-wrap { height: 280px; }
        .news-hero { height: 300px; }
        .news-article-body { padding: 1.5rem 1.25rem 2rem; }
    }

    @@media (max-width: 560px) {
        .news-content-wrapper { padding: 2rem 1.25rem 3.5rem; }
        .news-feature-img-wrap { height: 220px; }
        .news-article-title { font-size: 1.2rem; }
    }
</style>

<!-- ── HERO ── -->
<div class="news-hero">
    <div class="news-hero-bg" style="background-image: url('/images/4.jpg');"></div>
    <div class="news-hero-overlay"></div>
    <div class="news-hero-content">
        <p class="news-breadcrumb">
            <a href="/News/News">News</a> &nbsp;/&nbsp; PETRONAS OGSE Partners Day 2026
        </p>
        <h1 class="news-hero-title">PETRONAS OGSE Partners Day 2026 — Empowering Resilience</h1>
    </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="news-content-wrapper">
    <div class="news-layout">

        <!-- ── ARTICLE ── -->
        <article class="news-article">

            <!-- Feature Image -->
            <div class="news-feature-img-wrap">
                <img src="/images/news/ogse_partners_day_2026.jpg"
                     alt="PETRONAS OGSE Partners Day 2026 — Empowering Resilience, Kuala Lumpur Convention Centre"
                     class="news-feature-img" />
                <span class="news-img-tag">📌 Event</span>
            </div>

            <div class="news-article-body">

                <!-- Meta -->
                <div class="news-meta-row">
                    <div class="news-meta-item">
                        <span class="news-meta-icon">📅</span>
                        <span>April 23, 2026</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">🏢</span>
                        <span>Industry Engagement</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">📍</span>
                        <span>Kuala Lumpur Convention Centre</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">🏛️</span>
                        <span>PETRONAS / MPRC</span>
                    </div>
                </div>

                <!-- Title -->
                <h2 class="news-article-title">
                    Synergy Marine (M) Sdn Bhd Honoured to Participate in PETRONAS OGSE Partners Day 2026 — Empowering Resilience
                </h2>

                <!-- Lead -->
                <p class="news-lead">
                    Synergy Marine (M) Sdn Bhd was honoured to be part of the PETRONAS OGSE Partners Day 2026, held on 23 April 2026 at the Kuala Lumpur Convention Centre — a landmark event that brought together key stakeholders across Malaysia's Oil &amp; Gas Services and Equipment (OGSE) ecosystem under the theme of <strong>Empowering Resilience</strong>.
                </p>

                <p class="news-body-text">
                    Representing the company at this significant industry gathering were our Directors, Yg Berbahagia Dato' Dr. Roslan Ahmad and En. Asmawi Ilias. Their attendance underscores Synergy Marine's continued commitment to active engagement within Malaysia's upstream oil and gas services community and reinforces the company's standing as a trusted partner within the PETRONAS vendor and supplier network.
                </p>

                <p class="news-body-text">
                    The OGSE Partners Day 2026 served as a vital platform for dialogue and collaboration between PETRONAS and its ecosystem of local contractors, service providers, and equipment suppliers. Centered on the themes of resilience, competitiveness, and the energy transition, the event highlighted the industry's ongoing transformation and underscored the collective responsibility of the OGSE community in navigating future challenges — from energy security to decarbonisation.
                </p>

                <p class="news-body-text">
                    Notably, the Malaysia Petroleum Resources Corporation (MPRC) led several impactful sessions aligned with the National OGSE Industry Blueprint 2021–2030, covering critical areas including sustainability initiatives, long-term industry growth strategies, and capacity building for local players. These sessions provided invaluable insight into the direction of Malaysia's energy sector and the role that OGSE companies play in delivering national energy objectives.
                </p>

                <p class="news-body-text">
                    For Synergy Marine, participation in events such as OGSE Partners Day 2026 reflects our ongoing dedication to industry engagement, professional development, and positioning the company at the forefront of Malaysia's evolving energy landscape. As an Offshore Support Vessel (OSV) operator and integrated ship management company, Synergy Marine recognises the significance of the energy transition agenda and remains committed to aligning our operations and fleet strategy with sustainability principles and national energy priorities.
                </p>

                <p class="news-body-text">
                    Synergy Marine extends its sincere appreciation to PETRONAS and MPRC for organising this impactful and forward-looking event. We look forward to continued collaboration and partnership as we collectively chart a resilient and sustainable course for Malaysia's OGSE industry.
                </p>

                <!-- Caption -->
                <p class="news-caption">
                    Dato' Dr. Roslan Ahmad and En. Asmawi Ilias representing Synergy Marine (M) Sdn Bhd at the PETRONAS OGSE Partners Day 2026, held on 23 April 2026 at the Kuala Lumpur Convention Centre. | Source: Synergy Marine (M) Sdn Bhd.
                </p>

                <!-- Tags -->
                <div class="news-tags">
                    <span class="news-tag">PETRONAS</span>
                    <span class="news-tag">OGSE 2026</span>
                    <span class="news-tag">Empowering Resilience</span>
                    <span class="news-tag">Synergy Marine</span>
                    <span class="news-tag">MPRC</span>
                    <span class="news-tag">Energy Transition</span>
                    <span class="news-tag">Sustainability</span>
                    <span class="news-tag">Oil &amp; Gas</span>
                    <span class="news-tag">OSV</span>
                    <span class="news-tag">ESG</span>
                    <span class="news-tag">Malaysia</span>
                    <span class="news-tag">2026</span>
                    <span class="news-tag">KLCC</span>
                </div>

            </div>
        </article>

        <!-- ── SIDEBAR ── -->
        <aside class="news-sidebar">

            <!-- Event Highlight Badge -->
            <div class="news-badge-card">
                <span class="news-badge-icon">🤝</span>
                <div class="news-badge-title">PETRONAS OGSE Partners Day 2026</div>
                <div class="news-badge-sub">Empowering Resilience<br />Kuala Lumpur Convention Centre</div>
            </div>

            <!-- Event Details -->
            <div class="news-info-card">
                <div class="news-info-card-header">
                    <span>📋</span>
                    <div class="news-info-card-header-title">Event Details</div>
                </div>
                <div class="news-info-card-body">

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Date</div>
                            <div class="news-info-value">23 April 2026</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Venue</div>
                            <div class="news-info-value">Kuala Lumpur Convention Centre (KLCC)</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Theme</div>
                            <div class="news-info-value">Empowering Resilience</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Organiser</div>
                            <div class="news-info-value">PETRONAS &amp; MPRC</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Representing Synergy Marine</div>
                            <div class="news-info-value">
                                Dato' Dr. Roslan Ahmad<br />
                                <span style="color:#94a3b8; font-size:0.75rem;">En. Asmawi Ilias</span>
                            </div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Key Agenda</div>
                            <div class="news-info-value">
                                National OGSE Blueprint 2021–2030<br />
                                <span style="color:#94a3b8; font-size:0.75rem;">Energy Transition &amp; Sustainability</span>
                            </div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Category</div>
                            <div class="news-info-value">Industry Event &amp; Engagement</div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Back button -->
            <a href="/News/News" class="news-back-btn">
                ← Back to News
            </a>

        </aside>
    </div>
</div>
