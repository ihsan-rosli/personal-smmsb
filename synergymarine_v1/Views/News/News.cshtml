@{
    ViewData["Title"] = "News";
}

<style>
    /* ── HERO ── */
    .ni-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        height: 380px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding-bottom: 2.5rem;
    }

    .ni-hero-bg {
        position: absolute;
        inset: 0;
        background: url('/images/3.jpg') center center / cover no-repeat;
        filter: brightness(0.85);
        /* removed transform scale – saves a composite layer on load */
        transition: transform 8s ease;
        will-change: transform;
    }

    .ni-hero:hover .ni-hero-bg { transform: scale(1.03); }

    .ni-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,20,50,0.2) 0%, rgba(10,20,50,0.78) 100%);
    }

    .ni-hero-content {
        position: relative;
        z-index: 2;
        padding: 0 2rem;
        max-width: 1140px;
        margin: 0 auto;
        width: 100%;
    }

    .ni-breadcrumb {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #60a5fa;
        margin-bottom: 0.75rem;
    }

    .ni-hero-title {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.15;
        margin: 0 0 0.4rem;
    }

    /* ── CONTENT WRAPPER ── */
    .ni-content-wrapper {
        background: #f9fafb;
        border-radius: 16px 16px 0 0;
        margin-top: -2rem;
        position: relative;
        z-index: 3;
        box-shadow: 0 -4px 30px rgba(0,0,0,0.08);
        padding: 3rem 2rem 5rem;
        max-width: 1140px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    /* ── FILTER BAR ── */
    .ni-filter-bar {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        flex-wrap: wrap;
        margin-bottom: 2.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid #e2e8f0;
    }

    .ni-filter-label {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-right: 0.5rem;
    }

    .ni-filter-btn {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        color: #475569;
        font-size: 12px;
        font-weight: 600;
        padding: 0.4rem 1rem;
        border-radius: 20px;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s, color 0.15s;
    }

        .ni-filter-btn:hover,
        .ni-filter-btn.active {
            background: #1d4ed8;
            border-color: #1d4ed8;
            color: #fff;
        }

    /* ── FEATURED ── */
    .ni-featured {
        display: grid;
        grid-template-columns: 1.4fr 1fr;
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .ni-card-featured {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
        cursor: pointer;
        /* GPU-composited layer only on hover, not by default */
    }

        .ni-card-featured:hover {
            box-shadow: 0 12px 40px rgba(37,99,235,0.12);
            border-color: #bfdbfe;
            transform: translateY(-3px);
            text-decoration: none;
        }

        .ni-card-featured .ni-thumb-wrap { height: 300px; }
        .ni-card-featured .ni-card-body  { padding: 1.75rem; }
        .ni-card-featured .ni-card-title { font-size: 1.2rem; }

    /* ── CARD GRID ── */
    .ni-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
        margin-bottom: 1.5rem;
    }

    /* ── CARD ── */
    .ni-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        text-decoration: none;
        transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
        /*
         * content-visibility: auto lets the browser skip layout/paint
         * for off-screen cards until they scroll into view.
         */
        content-visibility: auto;
        contain-intrinsic-size: 0 340px; /* approximate card height */
    }

        .ni-card:hover {
            box-shadow: 0 10px 32px rgba(37,99,235,0.1);
            border-color: #bfdbfe;
            transform: translateY(-3px);
            text-decoration: none;
        }

    /* Thumb */
    .ni-thumb-wrap {
        position: relative;
        width: 100%;
        height: 200px;
        overflow: hidden;
        background: #f1f5f9;
        flex-shrink: 0;
    }

    .ni-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: top center;
        transition: transform 0.45s ease;
        display: block;
        /* avoids layout-shift jank while the image loads */
        will-change: transform;
    }

    .ni-card:hover .ni-thumb,
    .ni-card-featured:hover .ni-thumb { transform: scale(1.05); }

    /* Category pill */
    .ni-cat-pill {
        position: absolute;
        top: 0.85rem;
        left: 0.85rem;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.2px;
        text-transform: uppercase;
        padding: 0.3rem 0.75rem;
        border-radius: 20px;
        color: #fff;
        /* pills don't need their own layer */
    }

        .ni-cat-pill.award   { background: #d97706; }
        .ni-cat-pill.media   { background: #0f766e; }
        .ni-cat-pill.event   { background: #7c3aed; }
        .ni-cat-pill.company { background: #1d4ed8; }
        .ni-cat-pill.press   { background: #be185d; }
        .ni-cat-pill.csr     { background: #15803d; }

    /* Read-more overlay – use opacity only (cheaper than background repaint) */
    .ni-hover-overlay {
        position: absolute;
        inset: 0;
        background: rgba(15,37,87,0);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s;
    }

    .ni-card:hover .ni-hover-overlay,
    .ni-card-featured:hover .ni-hover-overlay { background: rgba(15,37,87,0.42); }

    .ni-read-label {
        background: rgba(255,255,255,0.95);
        color: #1e40af;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        padding: 0.4rem 1.1rem;
        border-radius: 20px;
        opacity: 0;
        transform: translateY(6px);
        transition: opacity 0.2s, transform 0.2s;
    }

    .ni-card:hover .ni-read-label,
    .ni-card-featured:hover .ni-read-label { opacity: 1; transform: translateY(0); }

    /* Card body */
    .ni-card-body {
        padding: 1.1rem 1.25rem 1.35rem;
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .ni-card-meta {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-size: 0.75rem;
        color: #94a3b8;
        font-weight: 500;
    }

    .ni-card-meta-dot {
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: #cbd5e1;
    }

    .ni-card-source {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #2563eb;
    }

    .ni-card-title {
        font-size: 0.92rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.4;
        flex: 1;
    }

    .ni-card-excerpt {
        font-size: 0.8rem;
        color: #6b7280;
        line-height: 1.6;
        margin-top: 0.2rem;
    }

    .ni-card-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        font-size: 11px;
        font-weight: 700;
        color: #2563eb;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-top: 0.6rem;
        transition: gap 0.15s;
    }

    .ni-card:hover .ni-card-cta,
    .ni-card-featured:hover .ni-card-cta { gap: 0.6rem; }

    /* Section label */
    .ni-section-label {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin-bottom: 1.25rem;
        margin-top: 2.5rem;
    }

    .ni-section-label-text {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #94a3b8;
        white-space: nowrap;
    }

    .ni-section-label-line {
        flex: 1;
        height: 1px;
        background: #e2e8f0;
    }

    /* Responsive */
    @@media (max-width: 960px) {
        .ni-featured { grid-template-columns: 1fr; }
        .ni-grid     { grid-template-columns: repeat(2, 1fr); }
    }

    @@media (max-width: 600px) {
        .ni-grid { grid-template-columns: 1fr; }
        .ni-hero { height: 280px; }
        .ni-content-wrapper { padding: 2rem 1.25rem 3.5rem; }
    }
</style>

