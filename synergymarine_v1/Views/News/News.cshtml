<script>
    // ── FILTER — runs in a single rAF to avoid mid-paint style thrashing ──
    (function () {
        var filterMap = {
            'All':            ['award','press','media','event','company','csr'],
            'Awards':         ['award'],
            'Media Coverage': ['press','media'],
            'Company News':   ['company'],
            'Events':         ['event'],
            'CSR':            ['csr']
        };

        // Cache DOM references once
        var allCards     = Array.from(document.querySelectorAll('[data-category]'));
        var allGrids     = Array.from(document.querySelectorAll('[data-grid]'));
        var allSections  = Array.from(document.querySelectorAll('[data-section]'));

        function applyFilter(cats) {
            // Batch all reads first, then batch writes (avoids forced reflow)
            var cardVisibility = allCards.map(function (c) {
                return cats.indexOf(c.getAttribute('data-category')) !== -1;
            });

            requestAnimationFrame(function () {
                // 1. Show / hide cards
                allCards.forEach(function (card, i) {
                    if (cardVisibility[i]) {
                        card.style.display = '';
                    } else {
                        card.style.display = 'none';
                    }
                });

                // 2. Hide empty grids
                allGrids.forEach(function (grid) {
                    var hasVisible = Array.from(
                        grid.querySelectorAll('[data-category]')
                    ).some(function (c) { return c.style.display !== 'none'; });
                    grid.style.display = hasVisible ? '' : 'none';
                });

                // 3. Hide orphaned section labels
                allSections.forEach(function (label) {
                    var sectionName = label.getAttribute('data-section');
                    var grid = document.querySelector('[data-grid="' + sectionName + '"]');
                    label.style.display = (grid && grid.style.display !== 'none') ? '' : 'none';
                });
            });
        }

        document.querySelectorAll('.ni-filter-btn').forEach(function (btn) {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.ni-filter-btn').forEach(function (b) {
                    b.classList.remove('active');
                });
                btn.classList.add('active');
                applyFilter(filterMap[btn.dataset.filter] || filterMap['All']);
            });
        });
    })();
</script>
