@{
    ViewData["Title"] = "MOSVA Annual General Meeting 2026 — A New Leadership Chapter";
}

<style>
    /* ── HERO ── */
    .news-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        height: 380px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding-bottom: 2.5rem;
    }

    .news-hero-bg {
        position: absolute;
        inset: 0;
        background: url('/images/3.jpg') center center / cover no-repeat;
        filter: brightness(0.85);
        transform: scale(1.03);
        transition: transform 8s ease;
    }

    .news-hero:hover .news-hero-bg { transform: scale(1.0); }

    .news-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,20,50,0.2) 0%, rgba(10,20,50,0.78) 100%);
    }

    .news-hero-content {
        position: relative;
        z-index: 2;
        padding: 0 2rem;
        max-width: 1140px;
        margin: 0 auto;
        width: 100%;
    }

    .news-breadcrumb {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #60a5fa;
        margin-bottom: 0.75rem;
    }

        .news-breadcrumb a { color: #60a5fa; text-decoration: none; }
        .news-breadcrumb a:hover { text-decoration: underline; }

    .news-hero-title {
        font-size: clamp(1.6rem, 3.5vw, 2.6rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.2;
        margin: 0;
        max-width: 780px;
    }

    /* ── CONTENT WRAPPER ── */
    .news-content-wrapper {
        background: #f9fafb;
        border-radius: 16px 16px 0 0;
        margin-top: -2rem;
        position: relative;
        z-index: 3;
        box-shadow: 0 -4px 30px rgba(0,0,0,0.08);
        padding: 3rem 2rem 5rem;
        max-width: 1140px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    /* ── ARTICLE LAYOUT ── */
    .news-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 3rem;
        align-items: start;
    }

    /* ── ARTICLE MAIN ── */
    .news-article {
        background: #ffffff;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

    .news-feature-img-wrap {
        width: 100%;
        height: 420px;
        overflow: hidden;
        position: relative;
        background: #f1f5f9;
    }

    .news-feature-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        display: block;
        transition: transform 6s ease;
    }

    .news-article:hover .news-feature-img { transform: scale(1.02); }

    .news-img-tag {
        position: absolute;
        top: 1.25rem;
        left: 1.25rem;
        background: #7c3aed;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0.35rem 0.85rem;
        border-radius: 20px;
    }

    .news-article-body { padding: 2rem 2.25rem 2.5rem; }

    .news-meta-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .news-meta-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: #64748b;
        font-weight: 500;
    }

    .news-meta-icon { font-size: 0.9rem; }

    .news-meta-divider {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: #cbd5e1;
    }

    .news-article-title {
        font-size: 1.45rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.35;
        margin-bottom: 1.5rem;
        letter-spacing: -0.3px;
    }

    .news-lead {
        font-size: 1rem;
        color: #374151;
        line-height: 1.85;
        font-weight: 500;
        margin-bottom: 1.5rem;
        padding: 1.1rem 1.4rem;
        background: #eff6ff;
        border-left: 4px solid #2563eb;
        border-radius: 0 8px 8px 0;
        text-align: justify;
    }

    .news-body-text {
        font-size: 0.95rem;
        color: #4b5563;
        line-height: 1.9;
        margin-bottom: 1.25rem;
        text-align: justify;
    }

    .news-caption {
        font-size: 0.78rem;
        color: #94a3b8;
        text-align: center;
        margin-top: -0.5rem;
        margin-bottom: 1.75rem;
        font-style: italic;
    }

    /* Presenter list */
    .news-presenter-list {
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1.5rem;
    }

    .news-presenter-list-title {
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 0.85rem;
    }

    .news-presenter-item {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        font-size: 0.87rem;
        color: #1e293b;
        font-weight: 500;
        padding: 0.4rem 0;
        border-bottom: 1px solid #f1f5f9;
    }

        .news-presenter-item:last-child { border-bottom: none; }

    .news-presenter-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #2563eb;
        flex-shrink: 0;
    }

    .news-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
    }

    .news-tag {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        padding: 0.3rem 0.7rem;
        letter-spacing: 0.3px;
    }

    /* ── SIDEBAR ── */
    .news-sidebar {
        position: static;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .news-info-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
    }

    .news-info-card-header {
        background: linear-gradient(135deg, #0f2557, #1e40af);
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .news-info-card-header-title {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #fff;
    }

    .news-info-card-body { padding: 1.25rem; }

    .news-info-row {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.7rem 0;
        border-bottom: 1px solid #f8fafc;
    }

        .news-info-row:last-child { border-bottom: none; }

    .news-info-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #2563eb;
        flex-shrink: 0;
        margin-top: 5px;
    }

    .news-info-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 0.15rem;
    }

    .news-info-value {
        font-size: 0.83rem;
        color: #1e293b;
        font-weight: 500;
        line-height: 1.45;
    }

    .news-badge-card {
        background: linear-gradient(145deg, #eff6ff, #dbeafe);
        border: 1px solid #bfdbfe;
        border-radius: 14px;
        padding: 1.5rem;
        text-align: center;
    }

    .news-badge-icon {
        font-size: 2.5rem;
        margin-bottom: 0.6rem;
        display: block;
    }

    .news-badge-title {
        font-size: 0.88rem;
        font-weight: 800;
        color: #1e3a8a;
        margin-bottom: 0.3rem;
        line-height: 1.3;
    }

    .news-badge-sub {
        font-size: 0.78rem;
        color: #1d4ed8;
        line-height: 1.5;
    }

    .news-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        color: #374151;
        font-size: 0.83rem;
        font-weight: 600;
        padding: 0.6rem 1.1rem;
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.15s, border-color 0.15s;
        width: 100%;
        justify-content: center;
    }

        .news-back-btn:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #374151;
            text-decoration: none;
        }

    @@media (max-width: 900px) {
        .news-layout { grid-template-columns: 1fr; }
        .news-feature-img-wrap { height: 280px; }
        .news-hero { height: 300px; }
        .news-article-body { padding: 1.5rem 1.25rem 2rem; }
    }

    @@media (max-width: 560px) {
        .news-content-wrapper { padding: 2rem 1.25rem 3.5rem; }
        .news-feature-img-wrap { height: 220px; }
        .news-article-title { font-size: 1.2rem; }
    }
</style>

<!-- ── HERO ── -->
<div class="news-hero">
    <div class="news-hero-bg" style="background-image: url('/images/4.jpg');"></div>
    <div class="news-hero-overlay"></div>
    <div class="news-hero-content">
        <p class="news-breadcrumb">
            <a href="/News/News">News</a> &nbsp;/&nbsp; MOSVA AGM 2026
        </p>
        <h1 class="news-hero-title">MOSVA Annual General Meeting 2026 — A New Leadership Chapter</h1>
    </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="news-content-wrapper">
    <div class="news-layout">

        <!-- ── ARTICLE ── -->
        <article class="news-article">

            <!-- Feature Image -->
            <div class="news-feature-img-wrap">
                <img src="/images/news/mosva_agm_2026.jpg"
                     alt="MOSVA Annual General Meeting 2026 — Synergy Marine"
                     class="news-feature-img" />
                <span class="news-img-tag">📌 Annual General Meeting</span>
            </div>

            <div class="news-article-body">

                <!-- Meta -->
                <div class="news-meta-row">
                    <div class="news-meta-item">
                        <span class="news-meta-icon">📅</span>
                        <span>2026</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">🏢</span>
                        <span>Events &amp; Engagements</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">📍</span>
                        <span>Malaysia</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">🌊</span>
                        <span>MOSVA</span>
                    </div>
                </div>

                <!-- Title -->
                <h2 class="news-article-title">
                    Synergy Marine Honoured to Attend MOSVA AGM 2026 — Marking a New Era of Leadership for Malaysia's OSV Industry
                </h2>

                <!-- Lead -->
                <p class="news-lead">
                    Synergy Marine (M) Sdn Bhd was honoured to attend the Malaysia OSV Owners' Association (MOSVA) Annual General Meeting (AGM) 2026 — an important milestone for the association and the broader maritime and offshore support vessel industry in Malaysia.
                </p>

                <p class="news-body-text">
                    The AGM marked the beginning of a defining new leadership chapter for MOSVA with the appointment of our Managing Director, YBhg. Dato' Dr. Roslan Ahmad, as the new President of the association, alongside the newly elected EXCO line-up. This transition of leadership brings with it a renewed sense of direction and purpose, reflecting the collective commitment of industry stakeholders to strengthen Malaysia's OSV sector and support its sustainable growth in an ever-evolving energy landscape.
                </p>

                <p class="news-body-text">
                    Prior to the AGM proceedings, MOSVA organised a series of highly engaging technical presentations during the morning session, bringing together prominent organisations from across the oil, gas, and maritime sectors. These sessions delivered valuable industry insights, developments, and perspectives that are directly relevant to the challenges and opportunities facing Malaysia's maritime and offshore support vessel community.
                </p>

                <!-- Presenters list -->
                <div class="news-presenter-list">
                    <div class="news-presenter-list-title">Technical Presenters — Morning Session</div>
                    <div class="news-presenter-item"><div class="news-presenter-dot"></div>Malaysia Petroleum Management (MPM)</div>
                    <div class="news-presenter-item"><div class="news-presenter-dot"></div>PETRONAS</div>
                    <div class="news-presenter-item"><div class="news-presenter-dot"></div>Caterpillar Inc. / Sime Industrial</div>
                    <div class="news-presenter-item"><div class="news-presenter-dot"></div>Pelita Akademi</div>
                    <div class="news-presenter-item"><div class="news-presenter-dot"></div>Aroona Solutions Group</div>
                    <div class="news-presenter-item"><div class="news-presenter-dot"></div>WHA Oil &amp; Gas Sdn Bhd</div>
                </div>

                <p class="news-body-text">
                    The event reflects MOSVA's continued commitment towards strengthening industry collaboration, enhancing stakeholder engagement, and supporting the sustainable growth of Malaysia's maritime and offshore support vessel industry. The diverse range of presentations underscored the importance of a unified, forward-thinking approach as the industry navigates energy transition, regulatory developments, and evolving operational demands.
                </p>

                <p class="news-body-text">
                    Synergy Marine (M) Sdn Bhd looks forward to actively supporting MOSVA's future initiatives and contributing meaningfully towards the continued progress of the industry under the new leadership team. We are proud to stand alongside our industry peers as we collectively chart the course for a stronger, more resilient Malaysian OSV sector.
                </p>

                <!-- Caption -->
                <p class="news-caption">
                    Synergy Marine (M) Sdn Bhd representatives at the MOSVA Annual General Meeting 2026, alongside industry leaders and the newly elected MOSVA EXCO. | Malaysia, 2026.
                </p>

                <!-- Tags -->
                <div class="news-tags">
                    <span class="news-tag">Synergy Marine</span>
                    <span class="news-tag">MOSVA</span>
                    <span class="news-tag">AGM 2026</span>
                    <span class="news-tag">OSV</span>
                    <span class="news-tag">Offshore Support Vessel</span>
                    <span class="news-tag">Oil &amp; Gas</span>
                    <span class="news-tag">Industry Leadership</span>
                    <span class="news-tag">Marine Industry</span>
                    <span class="news-tag">PETRONAS</span>
                    <span class="news-tag">MPM</span>
                    <span class="news-tag">2026</span>
                </div>

            </div>
        </article>

        <!-- ── SIDEBAR ── -->
        <aside class="news-sidebar">

            <!-- Highlight Badge -->
            <div class="news-badge-card">
                <span class="news-badge-icon">🌊</span>
                <div class="news-badge-title">MOSVA AGM 2026</div>
                <div class="news-badge-sub">Malaysia OSV Owners' Association<br />Annual General Meeting</div>
            </div>

            <!-- Event Details -->
            <div class="news-info-card">
                <div class="news-info-card-header">
                    <span>📋</span>
                    <div class="news-info-card-header-title">Event Details</div>
                </div>
                <div class="news-info-card-body">

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Event</div>
                            <div class="news-info-value">MOSVA Annual General Meeting (AGM) 2026</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Organiser</div>
                            <div class="news-info-value">Malaysia OSV Owners' Association (MOSVA)</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Key Milestone</div>
                            <div class="news-info-value">Appointment of Dato' Dr. Roslan Ahmad as MOSVA President</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Morning Session</div>
                            <div class="news-info-value">Technical Presentations by MPM, PETRONAS, Caterpillar / Sime Industrial, Pelita Akademi, Aroona Solutions Group, WHA Oil &amp; Gas</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Year</div>
                            <div class="news-info-value">2026</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Reported By</div>
                            <div class="news-info-value">Synergy Marine (M) Sdn Bhd</div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Back button -->
            <a href="/News/News" class="news-back-btn">
                ← Back to News
            </a>

        </aside>
    </div>
</div>
