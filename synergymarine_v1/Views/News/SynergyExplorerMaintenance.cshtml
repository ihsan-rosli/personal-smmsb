@{
    ViewData["Title"] = "MV Synergy Explorer – Maintenance Works";
}

<style>
    /* ── HERO ── */
    .news-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        height: 380px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding-bottom: 2.5rem;
    }

    .news-hero-bg {
        position: absolute;
        inset: 0;
        background: url('/images/careerimg.jpg') center center / cover no-repeat;
        filter: brightness(0.85);
        transform: scale(1.03);
        transition: transform 8s ease;
    }

    .news-hero:hover .news-hero-bg {
        transform: scale(1.0);
    }

    .news-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,20,50,0.2) 0%, rgba(10,20,50,0.78) 100%);
    }

    .news-hero-content {
        position: relative;
        z-index: 2;
        padding: 0 2rem;
        max-width: 1140px;
        margin: 0 auto;
        width: 100%;
    }

    .news-breadcrumb {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #60a5fa;
        margin-bottom: 0.75rem;
    }

        .news-breadcrumb a {
            color: #60a5fa;
            text-decoration: none;
        }

            .news-breadcrumb a:hover {
                text-decoration: underline;
            }

    .news-hero-title {
        font-size: clamp(1.6rem, 3.5vw, 2.6rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.2;
        margin: 0;
        max-width: 780px;
    }

    /* ── CONTENT WRAPPER ── */
    .news-content-wrapper {
        background: #f9fafb;
        border-radius: 16px 16px 0 0;
        margin-top: -2rem;
        position: relative;
        z-index: 3;
        box-shadow: 0 -4px 30px rgba(0,0,0,0.08);
        padding: 3rem 2rem 5rem;
        max-width: 1140px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    /* ── ARTICLE LAYOUT ── */
    .news-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 3rem;
        align-items: start;
    }

    /* ── ARTICLE MAIN ── */
    .news-article {
        background: #ffffff;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }

    /* Feature image */
    .news-feature-img-wrap {
        width: 100%;
        height: 420px;
        overflow: hidden;
        position: relative;
        background: #f1f5f9;
    }

    .news-feature-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        display: block;
        transition: transform 6s ease;
    }

    .news-article:hover .news-feature-img {
        transform: scale(1.02);
    }

    /* Category tag over image */
    .news-img-tag {
        position: absolute;
        top: 1.25rem;
        left: 1.25rem;
        background: #1d4ed8;
        color: #fff;
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        padding: 0.35rem 0.85rem;
        border-radius: 20px;
    }

    /* Article body */
    .news-article-body {
        padding: 2rem 2.25rem 2.5rem;
    }

    /* Meta row */
    .news-meta-row {
        display: flex;
        align-items: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding-bottom: 1.25rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .news-meta-item {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        font-size: 0.8rem;
        color: #64748b;
        font-weight: 500;
    }

    .news-meta-icon {
        font-size: 0.9rem;
    }

    .news-meta-divider {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: #cbd5e1;
    }

    /* Article title */
    .news-article-title {
        font-size: 1.45rem;
        font-weight: 800;
        color: #0f172a;
        line-height: 1.35;
        margin-bottom: 1.5rem;
        letter-spacing: -0.3px;
    }

    /* Lead paragraph */
    .news-lead {
        font-size: 1rem;
        color: #374151;
        line-height: 1.85;
        font-weight: 500;
        margin-bottom: 1.5rem;
        padding: 1.1rem 1.4rem;
        background: #eff6ff;
        border-left: 4px solid #2563eb;
        border-radius: 0 8px 8px 0;
        text-align: justify;
    }

    .news-body-text {
        font-size: 0.95rem;
        color: #4b5563;
        line-height: 1.9;
        margin-bottom: 1.25rem;
        text-align: justify;
    }

    /* Takeaway list */
    .news-takeaway-list {
        list-style: none;
        padding: 0;
        margin: 0 0 1.5rem 0;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .news-takeaway-item {
        display: flex;
        align-items: flex-start;
        gap: 0.9rem;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 0.9rem 1.1rem;
    }

    .news-takeaway-num {
        background: #1d4ed8;
        color: #fff;
        font-size: 11px;
        font-weight: 800;
        min-width: 26px;
        height: 26px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-top: 1px;
    }

    .news-takeaway-text {
        font-size: 0.9rem;
        color: #1e293b;
        line-height: 1.55;
    }

        .news-takeaway-text strong {
            color: #0f172a;
            font-weight: 700;
        }

    /* Image caption */
    .news-caption {
        font-size: 0.78rem;
        color: #94a3b8;
        text-align: justify;
        margin-top: -0.5rem;
        margin-bottom: 1.75rem;
        font-style: italic;
    }

    /* Tags */
    .news-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 2rem;
        padding-top: 1.5rem;
        border-top: 1px solid #f1f5f9;
    }

    .news-tag {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        border-radius: 6px;
        font-size: 11px;
        font-weight: 600;
        padding: 0.3rem 0.7rem;
        letter-spacing: 0.3px;
    }

    /* ── SIDEBAR ── */
    .news-sidebar {
        position: static;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    /* Info card */
    .news-info-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 14px;
        overflow: hidden;
    }

    .news-info-card-header {
        background: linear-gradient(135deg, #0f2557, #1e40af);
        padding: 1rem 1.25rem;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .news-info-card-header-title {
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #fff;
    }

    .news-info-card-body {
        padding: 1.25rem;
    }

    .news-info-row {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        padding: 0.7rem 0;
        border-bottom: 1px solid #f8fafc;
    }

        .news-info-row:last-child {
            border-bottom: none;
        }

    .news-info-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #2563eb;
        flex-shrink: 0;
        margin-top: 5px;
    }

    .news-info-label {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #94a3b8;
        margin-bottom: 0.15rem;
    }

    .news-info-value {
        font-size: 0.83rem;
        color: #1e293b;
        font-weight: 500;
        line-height: 1.45;
    }

    /* Badge card */
    .news-badge-card {
        background: linear-gradient(145deg, #eff6ff, #dbeafe);
        border: 1px solid #bfdbfe;
        border-radius: 14px;
        padding: 1.5rem;
        text-align: center;
    }

    .news-badge-icon {
        font-size: 2.5rem;
        margin-bottom: 0.6rem;
        display: block;
    }

    .news-badge-title {
        font-size: 0.88rem;
        font-weight: 800;
        color: #1e3a8a;
        margin-bottom: 0.3rem;
        line-height: 1.3;
    }

    .news-badge-sub {
        font-size: 0.78rem;
        color: #1d4ed8;
        line-height: 1.5;
    }

    /* Back button */
    .news-back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: #ffffff;
        border: 1px solid #e2e8f0;
        color: #374151;
        font-size: 0.83rem;
        font-weight: 600;
        padding: 0.6rem 1.1rem;
        border-radius: 8px;
        text-decoration: none;
        transition: background 0.15s, border-color 0.15s;
        width: 100%;
        justify-content: center;
    }

        .news-back-btn:hover {
            background: #f8fafc;
            border-color: #cbd5e1;
            color: #374151;
            text-decoration: none;
        }

    /* ── RESPONSIVE ── */
    @@media (max-width: 900px) {
        .news-layout {
            grid-template-columns: 1fr;
        }

        .news-sidebar {
            position: static;
        }

        .news-feature-img-wrap {
            height: 280px;
        }

        .news-hero {
            height: 300px;
        }

        .news-article-body {
            padding: 1.5rem 1.25rem 2rem;
        }
    }

    @@media (max-width: 560px) {
        .news-content-wrapper {
            padding: 2rem 1.25rem 3.5rem;
        }

        .news-feature-img-wrap {
            height: 220px;
        }

        .news-article-title {
            font-size: 1.2rem;
        }
    }
</style>

<!-- ── HERO ── -->
<div class="news-hero">
    <div class="news-hero-bg" style="background-image: url('/images/5.jpg');"></div>
    <div class="news-hero-overlay"></div>
    <div class="news-hero-content">
        <p class="news-breadcrumb">
            <a href="/News/News">News</a> &nbsp;/&nbsp; MV Synergy Explorer – Maintenance Works
        </p>
        <h1 class="news-hero-title">MV Synergy Explorer – Maintenance Works</h1>
    </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="news-content-wrapper">
    <div class="news-layout">

        <!-- ── ARTICLE ── -->
        <article class="news-article">

            <!-- Feature Image -->
            <div class="news-feature-img-wrap">
                <img src="/images/news/synergyexplorermaintenance.png"
                     alt="MV Synergy Explorer Maintenance Works"
                     class="news-feature-img" />
                <span class="news-img-tag">🛠️ Operations</span>
            </div>

            <div class="news-article-body">

                <!-- Meta -->
                <div class="news-meta-row">
                    <div class="news-meta-item">
                        <span class="news-meta-icon">📅</span>
                        <span>December 18, 2025</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">🏢</span>
                        <span>Vessel Maintenance</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">📍</span>
                        <span>Malaysia</span>
                    </div>
                    <div class="news-meta-divider"></div>
                    <div class="news-meta-item">
                        <span class="news-meta-icon">📰</span>
                        <span>LinkedIn & Facebook</span>
                    </div>
                </div>

                <!-- Title -->
                <h2 class="news-article-title">
                    MV Synergy Explorer – Maintenance Works
                </h2>

                <!-- Lead -->
                <p class="news-lead">
                    As part of our ongoing commitment to vessel safety and reliability, MV Synergy Explorer recently underwent planned maintenance works covering inspections, servicing, and essential repairs.
                </p>

                <p class="news-body-text">
                    These maintenance activities were carried out to ensure the vessel remains in optimal operating condition, supporting safe and efficient offshore operations.
                </p>

                <p class="news-body-text">
                    The maintenance site visit was attended by Dato’ Dr Roslan Ahmad, Managing Director, and En Mohd Asmawi Ilias, Finance Director of Synergy Marine (M) Sdn Bhd, reflecting management’s strong involvement and commitment to maintaining high operational standards.
                </p>

                <p class="news-body-text">
                    Our appreciation goes to the vessel’s Master and crew, technical team, and all parties involved for their professionalism and teamwork throughout the maintenance period.
                </p>

                <p class="news-body-text">
                    MV Synergy Explorer now stands ready to continue supporting offshore operations safely and reliably.
                </p>

                <!-- Caption -->
                <p class="news-caption">
                    MV Synergy Explorer undergoing maintenance works to ensure operational readiness | December 2025.
                </p>

                <!-- Tags -->
                <div class="news-tags">
                    <span class="news-tag">Maintenance</span>
                    <span class="news-tag">Vessel</span>
                    <span class="news-tag">Synergy Explorer</span>
                    <span class="news-tag">Offshore</span>
                    <span class="news-tag">Marine Operations</span>
                    <span class="news-tag">Safety</span>
                    <span class="news-tag">Reliability</span>
                    <span class="news-tag">2025</span>
                </div>

            </div>
        </article>

        <!-- ── SIDEBAR ── -->
        <aside class="news-sidebar">

            <!-- Achievement Highlight -->
            <div class="news-badge-card">
                <span class="news-badge-icon">🛠️</span>
                <div class="news-badge-title">Maintenance & Operational Readiness</div>
                <div class="news-badge-sub">
                    Ensuring vessel safety and reliability<br />
                    Through continuous maintenance efforts
                </div>
            </div>

            <!-- Event Details -->
            <div class="news-info-card">
                <div class="news-info-card-header">
                    <span>📋</span>
                    <div class="news-info-card-header-title">Maintenance Details</div>
                </div>
                <div class="news-info-card-body">

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Vessel</div>
                            <div class="news-info-value">MV Synergy Explorer</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Date</div>
                            <div class="news-info-value">December 2025</div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Scope</div>
                            <div class="news-info-value">
                                Inspection, Servicing &amp; Repairs
                            </div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Attended By</div>
                            <div class="news-info-value">
                                Dato’ Dr Roslan Ahmad<br />
                                <span style="color:#94a3b8; font-size:0.75rem;">Managing Director</span><br />
                                En Mohd Asmawi Ilias<br />
                                <span style="color:#94a3b8; font-size:0.75rem;">Finance Director</span>
                            </div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Focus</div>
                            <div class="news-info-value">
                                Safety, Reliability &amp; Operational Readiness
                            </div>
                        </div>
                    </div>

                    <div class="news-info-row">
                        <div class="news-info-dot"></div>
                        <div>
                            <div class="news-info-label">Source</div>
                            <div class="news-info-value">
                                LinkedIn &amp; Facebook
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- Back button -->
            <a href="/News/News" class="news-back-btn">
                ← Back to News
            </a>
        </aside>
    </div>
</div>
