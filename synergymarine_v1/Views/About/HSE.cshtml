@{
    ViewData["Title"] = "HSE";
}

<style>
    /* ── HERO SECTION ── */
    .cp-hero {
        position: relative;
        width: 100vw;
        margin-left: calc(-50vw + 50%);
        height: 380px;
        overflow: hidden;
        display: flex;
        align-items: flex-end;
        padding-bottom: 2.5rem;
    }

    .cp-hero-bg {
        position: absolute;
        inset: 0;
        background: url('/images/comp4.jpg') center center / cover no-repeat;
        filter: brightness(0.85);
        transform: scale(1.03);
        transition: transform 8s ease;
    }

    .cp-hero:hover .cp-hero-bg {
        transform: scale(1.0);
    }

    .cp-hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(10,20,50,0.2) 0%, rgba(10,20,50,0.75) 100%);
    }

    .cp-hero-content {
        position: relative;
        z-index: 2;
        padding: 0 2rem;
        max-width: 1140px;
        margin: 0 auto;
        width: 100%;
    }

    .cp-breadcrumb {
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #60a5fa;
        margin-bottom: 0.75rem;
    }

    .cp-hero-title {
        font-size: clamp(2rem, 4vw, 3rem);
        font-weight: 700;
        color: #ffffff;
        letter-spacing: -0.5px;
        line-height: 1.15;
        margin: 0;
    }

    /* ── CONTENT WRAPPER ── */
    .cp-content-wrapper {
        background: #ffffff;
        border-radius: 16px 16px 0 0;
        margin-top: -2rem;
        position: relative;
        z-index: 3;
        box-shadow: 0 -4px 30px rgba(0,0,0,0.08);
        padding: 3rem 2rem 4rem;
        max-width: 1140px;
        margin-left: auto;
        margin-right: auto;
        width: 100%;
    }

    .cp-lead-heading {
        font-size: 1.35rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.4;
        margin-bottom: 0.5rem;
        border-left: 4px solid #dc2626;
        padding-left: 1rem;
    }

    .cp-sub-text {
        font-size: 0.95rem;
        color: #6b7280;
        margin-bottom: 2rem;
        padding-left: 1.25rem;
    }

    .cp-divider {
        border: none;
        border-top: 1px solid #e5e7eb;
        margin-bottom: 2rem;
    }

    /* ── TAB BUTTONS ── */
    .tab-buttons {
        display: flex;
        flex-wrap: wrap;
        background-color: #f1f5f9;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 8px;
        gap: 6px;
        margin-bottom: 1.5rem;
    }

    .tab-btn {
        background-color: transparent;
        border: none;
        padding: 10px 18px;
        font-size: 0.88rem;
        font-weight: 600;
        color: #64748b;
        cursor: pointer;
        border-radius: 6px;
        transition: all 0.2s ease;
        flex-grow: 1;
        text-align: center;
        white-space: nowrap;
    }

        .tab-btn:hover {
            background-color: #e2e8f0;
            color: #1e293b;
        }

        .tab-btn.active {
            background-color: #1a365d;
            color: #ffffff;
            box-shadow: 0 2px 6px rgba(0,0,0,0.15);
        }

    /* ── TAB CONTENT ── */
    .hse-container {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
    }

    .tab-content {
        display: none;
        animation: fadeInTab 0.35s ease;
        min-height: 420px;
    }

        .tab-content.active {
            display: flex;
        }

    @@keyframes fadeInTab {
        from {
            opacity: 0;
            transform: translateY(6px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Image Side */
    .policy-image {
        width: 38%;
        background-color: #f8fafc;
        flex-shrink: 0;
    }

        .policy-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            min-height: 400px;
            display: block;
        }

    /* Text Side */
    .policy-desc {
        width: 62%;
        padding: 2.5rem 2.5rem 2.5rem 2.5rem;
        overflow-y: auto;
        max-height: 560px;
    }

        .policy-desc h3 {
            color: #1a365d;
            margin-bottom: 0.4rem;
            font-size: 1.3rem;
            font-weight: 700;
        }

        .policy-desc .policy-tag {
            display: inline-block;
            background: #eff6ff;
            color: #dc2626;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 1px;
            text-transform: uppercase;
            border-radius: 4px;
            padding: 0.2rem 0.6rem;
            margin-bottom: 1.5rem;
        }

        .policy-desc p {
            font-size: 0.93rem;
            line-height: 1.85;
            color: #4b5563;
            margin-bottom: 1.25rem;
        }

        .policy-desc .policy-section-title {
            font-size: 0.85rem;
            font-weight: 700;
            color: #1a365d;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-top: 1.5rem;
            margin-bottom: 0.75rem;
            border-bottom: 2px solid #e5e7eb;
            padding-bottom: 0.4rem;
        }

        .policy-desc ul {
            margin: 0 0 1.25rem 0;
            padding-left: 1.4rem;
        }

            .policy-desc ul li {
                font-size: 0.93rem;
                line-height: 1.85;
                color: #4b5563;
                margin-bottom: 0.5rem;
            }

    /* ── RESPONSIVE ── */
    @@media (max-width: 768px) {
        .cp-hero {
            height: 280px;
        }

        .tab-content.active {
            flex-direction: column;
        }

        .policy-image,
        .policy-desc {
            width: 100%;
        }

            .policy-image img {
                min-height: 220px;
                max-height: 260px;
            }

        .policy-desc {
            padding: 1.5rem;
            max-height: none;
        }

        .cp-content-wrapper {
            padding: 2rem 1.25rem 3rem;
        }

        .tab-btn {
            font-size: 0.8rem;
            padding: 8px 10px;
        }
    }
</style>

<!-- ── HERO ── -->
<div class="cp-hero">
    <div class="cp-hero-bg"></div>
    <div class="cp-hero-overlay"></div>
    <div class="cp-hero-content">
        <p class="cp-breadcrumb">About Us / HSE Policies</p>
        <h1 class="cp-hero-title">Health, Safety & Environment</h1>
    </div>
</div>

<!-- ── MAIN CONTENT ── -->
<div class="cp-content-wrapper">

    <p class="cp-lead-heading">We provide for safe practices in ship operation</p>
    <p class="cp-sub-text">Ensuring the highest standards of safety, health, security and environmental care in all our operations.</p>

    <!-- Tab Buttons -->
    <div class="tab-buttons">
        <button class="tab-btn active" onclick="openPolicy(event, 'policy1')">Safety Management</button>
        <button class="tab-btn" onclick="openPolicy(event, 'policy2')">HSSE Policy</button>
        <button class="tab-btn" onclick="openPolicy(event, 'policy3')">Drug & Alcohol</button>
        <button class="tab-btn" onclick="openPolicy(event, 'policy4')">Ethics & Personnel</button>


    <!-- Tab Contents -->
    <div class="hse-container">

        <!-- TAB 1: Safety Management System Policy -->
        <div id="policy1" class="tab-content active">
            <div class="policy-image">
                <img src="~/images/hse/health&safetypolicy.jpg" alt="Safety Management System" />
            </div>
            <div class="policy-desc">
                <h3>Safety Management System Policy</h3>
                <span class="policy-tag">SMS</span>
                <p>Synergy Marine (M) Sdn Bhd (SMMSB) shall set up an effective and appropriate Safety Management System (SMS) to ensure that quality and reliability of the management services of the ship maintained by the company, for safe and reliable operation and environmental protection. The Company shall maintain this policy, and always aim to improve the services.</p>
                <p>SMMSB has established the Safety Management System complying with the requirements of International Safety Management Code (ISM Code) for achieving this policy. The established Safety Management System is applicable to all related departments and to ships owned or managed by the company.</p>

                <p class="policy-section-title">SMS Objectives</p>
                <ul>
                    <li>Ensure safety at sea, prevention of human injury or loss of life, and avoidance of damage to the environment, in particular, to the marine environment, and to property.</li>
                    <li>Provide for the safe practices in ship operation and a safe working environment.</li>
                    <li>Assess all identified risks to its ships, personnel ashore and the environment and establish appropriate safeguards.</li>
                    <li>Continuously improve safety management skills of personnel ashore and aboard ships, including preparing for emergencies related to safety and environmental protection.</li>
                    <li>Ensure compliance with mandatory rules and regulations and that applicable codes, guidelines and standards recommended by the International Maritime Organization (IMO), Administrations, Classification Societies, and Maritime Industry organizations are taken into account.</li>
                </ul>

                <p>All employees are to adhere to this policy.</p>
            </div>
        </div>

        <!-- TAB 2: HSSE Policy -->
        <div id="policy2" class="tab-content">
            <div class="policy-image">
                <img src="~/images/hse/health&safetypolicy.jpg" alt="HSSE Policy" />
            </div>
            <div class="policy-desc">
                <h3>Health, Safety, Security & Environmental Policy</h3>
                <span class="policy-tag">HSSE</span>
                <p>Synergy Marine (M) Sdn Bhd (SMMSB) is fully committed to Health, Safety, Security and Environment excellence in all its business activities wherever it operates. SMMSB will comply with all applicable Rules and Regulation requirements and maintain best practices in Occupational Safety and Health Standards.</p>
                <p>It has been the company's vision and aspiration to achieve zero injury to people, zero damage to property and zero pollution to the environment as a long-term goal, as well as to detect security threats and take preventive measures against security incidents affecting ships.</p>

                <p class="policy-section-title">Company Objectives</p>
                <ul>
                    <li>Provide for safe practices in ship operation and a safe working environment.</li>
                    <li>Establish practical safeguards against all identified risks so that the number of accidents, incidents and hazardous occurrences is minimised.</li>
                    <li>Continuously improve the safety management skills of personnel ashore and onboard ships, including preparing for emergencies related both to safety and environmental protection.</li>
                    <li>Compliance with mandatory rules and regulations.</li>
                    <li>Ensure that applicable codes, guidelines and standards recommended by the Organization, Administrations, classification society and maritime industry organization are taken into account.</li>
                </ul>

                <p class="policy-section-title">These Objectives Will Be Achieved By</p>
                <ul>
                    <li>Implementing and continuously improving the SMMSB Safety Management System.</li>
                    <li>Actively promoting employee participation in measures aimed at improving safety and protecting the environment.</li>
                    <li>Keeping all personnel fully informed of any known or potential hazards that may affect themselves, their colleagues, the ship and the environment. All events are reported, lessons learned from incidents or accidents are shared to prevent recurrence.</li>
                    <li>Empowering and reinforcing the right of employees and contractor staff to use the Stop Work Authority (SWA).</li>
                    <li>Continuously reviewing all mandatory rules, regulations, industry codes and operating procedures relevant to specific ship types and trade to ensure effectiveness and continual improvement.</li>
                </ul>

                <p>SMMSB requires its employees, visitors and contractors to strictly adhere to this policy at all times.</p>
            </div>
        </div>

        <!-- TAB 3: Drug & Alcohol Policy -->
        <div id="policy3" class="tab-content">
            <div class="policy-image">
                <img src="~/images/hse/health&safetypolicy.jpg" alt="Drug and Alcohol" />
            </div>
            <div class="policy-desc">
                <h3>Drug & Alcohol Policy</h3>
                <span class="policy-tag">Safety</span>
                <p>Synergy Marine (M) Sdn Bhd is committed to the health, safety and welfare of personnel. The health, safety and welfare of personnel can be seriously affected by the consumption of alcohol, un-prescribed controlled drugs and other substance abuse.</p>
                <p>SMMSB has <strong>Zero Tolerance</strong> to drugs and alcohol use and/or possession of equipment in the workplace.</p>
                <p>Therefore, the use, consumption, supply, possession, concealment, transportation, purchase, manufacture, promotion or sale of un-prescribed drugs and alcohol is <strong>strictly prohibited</strong> on SMMSB vessels (Owned or Managed) and office (shore base).</p>
                <p>A violation of this Policy by any individual of the Company is likely to result in the individual being summarily dismissed or terminated from employment. A violation by third party personnel will result in the offending party or parties being removed from the vessel.</p>
                <p>SMMSB <strong>reserves the right</strong> to conduct breath testing, blood analysis and/or urine testing and/or search a person and their personal possessions at any time.</p>
                <p>All SMMSB personnel shall not consume drugs and alcohol in any country where the consumption of drugs and alcohol is forbidden by law.</p>
            </div>
        </div>

        <!-- TAB 4: Ethics Policy -->
        <div id="policy4" class="tab-content">
            <div class="policy-image">
                <img src="~/images/hse/health&safetypolicy.jpg" alt="Ethics" />
            </div>
            <div class="policy-desc">
                    <h3>Ethics & Personnel Policy</h3>
                <span class="policy-tag">Integrity</span>
                <p>Synergy Marine (M) Sdn Bhd is committed to conducting business in an honest and ethical way, and without the use of corrupt practices or acts of bribery to obtain an unfair advantage, ensuring our activities remain consistent with the applicable laws and regulations of the countries in which we operate.</p>
                <p>Bribery and corruption harm the societies in which the acts are committed. Such behaviour undermines the economy, brings disorder to the markets and curtails development.</p>
                <p>All employees are expected to be honest in their dealings with clients, vendors, all other stakeholders and with each other, respecting individual rights and ensuring that their actions are free from discrimination, racism, corruption, and slander.</p>
                <p>Through a process of internal communication and auditing, the Company ensures that all employees are made aware of this Policy and that they familiarise themselves with, understand, and comply with associated instructions and procedures.</p>
            </div>
        </div>



    </div>
</div>

<script>
    function openPolicy(evt, policyName) {
        document.querySelectorAll('.tab-content').forEach(el => {
            el.style.display = 'none';
            el.classList.remove('active');
        });
        document.querySelectorAll('.tab-btn').forEach(btn => {
            btn.classList.remove('active');
        });
        const target = document.getElementById(policyName);
        target.style.display = 'flex';
        target.classList.add('active');
        evt.currentTarget.classList.add('active');
    }
</script>
