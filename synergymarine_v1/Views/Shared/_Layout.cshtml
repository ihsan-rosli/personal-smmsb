    <script>
        // ── Page Loader ──
        window.addEventListener('load', function () {
            setTimeout(function () {
                document.getElementById('pageLoader').classList.add('hidden');
            }, 100);
        });

        // ── Navbar scroll shadow ──
        window.addEventListener('scroll', function () {
            document.getElementById('mainNavbar').classList.toggle('scrolled', window.scrollY > 50);
        }, { passive: true });

        // ── Smooth scroll ──
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                const target = document.querySelector(this.getAttribute('href'));
                if (target) { e.preventDefault(); target.scrollIntoView({ behavior: 'smooth', block: 'start' }); }
            });
        });

        // ── Active nav link ──
        document.addEventListener('DOMContentLoaded', function () {
            const path = window.location.pathname.toLowerCase();
            document.querySelectorAll('.navbar-nav .nav-link').forEach(link => {
                const href = (link.getAttribute('href') || '').toLowerCase();
                if (href && href !== '#' && path.includes(href)) link.classList.add('active');
            });
        });

        // ══════════════════════════════════════════════════════════════
        //  BACKGROUND MUSIC — seamless cross-page continuity
        //  Strategy:
        //    1. Save currentTime to sessionStorage every 250ms + on unload
        //    2. On new page: seek to saved time BEFORE calling play()
        //    3. Attempt play immediately (works if browser already unlocked)
        //    4. If blocked, wait for first user interaction then retry
        // ══════════════════════════════════════════════════════════════
        (function () {
            const video = document.getElementById('bgMusic');
            const btn   = document.getElementById('musicBtn');
            const icon  = document.getElementById('musicIcon');

            const savedMuted = sessionStorage.getItem('musicMuted') === 'true';
            const savedTime  = parseFloat(sessionStorage.getItem('musicTime') || '0');

            function updateBtn(muted) {
                if (muted) {
                    icon.className = 'fas fa-volume-mute';
                    btn.classList.remove('playing');
                    btn.title = 'Play music';
                } else {
                    icon.className = 'fas fa-volume-up';
                    btn.classList.add('playing');
                    btn.title = 'Mute music';
                }
            }

            // Save playback position frequently so cross-page resume is accurate
            setInterval(function () {
                if (!video.paused) {
                    sessionStorage.setItem('musicTime', video.currentTime);
                }
            }, 250);

            // Save right before the page unloads (most accurate snapshot)
            window.addEventListener('beforeunload', function () {
                sessionStorage.setItem('musicTime', video.currentTime);
                sessionStorage.setItem('musicMuted', video.muted);
            });

            // Core play function: seek to saved position THEN play, THEN apply mute pref
            function attemptPlay() {
                if (savedTime > 0) {
                    video.currentTime = savedTime;
                }
                video.muted  = false;   // must be unmuted before play() or browser may block
                video.volume = 1;

                return video.play().then(function () {
                    // Restore user's mute preference after play has started
                    video.muted = savedMuted;
                    updateBtn(savedMuted);
                });
            }

            // Try to play immediately (succeeds on page 2+ once browser has unlocked audio)
            attemptPlay().catch(function () {
                // First visit or browser blocked autoplay — show muted state, wait for gesture
                updateBtn(true);

                var events = ['click', 'scroll', 'touchstart', 'keydown', 'mousemove'];
                function tryPlay() {
                    attemptPlay().then(function () {
                        events.forEach(function (ev) {
                            document.removeEventListener(ev, tryPlay);
                        });
                    }).catch(function () {});
                }
                events.forEach(function (ev) {
                    document.addEventListener(ev, tryPlay, { passive: true });
                });
            });

            // Toggle mute/unmute button
            btn.addEventListener('click', function (e) {
                e.stopPropagation();
                var nowMuted = !video.muted;
                video.muted  = nowMuted;
                sessionStorage.setItem('musicMuted', nowMuted);
                updateBtn(nowMuted);
                if (video.paused) { video.play().catch(function () {}); }
            });

            // Set initial button state while play is still pending
            updateBtn(savedMuted);
        })();
    </script>

    <script>
        // ════════════════════════════════
        //  CONTENT PROTECTION + COPY WARNING TOAST
        // ════════════════════════════════

        (function () {
            const toast = document.getElementById('copy-warning-toast');
            let toastTimer = null;

            // Show the red warning toast
            function showWarning() {
                clearTimeout(toastTimer);
                toast.classList.add('show');
                toastTimer = setTimeout(function () {
                    toast.classList.remove('show');
                }, 2800);
            }

            // Disable right-click context menu
            document.addEventListener('contextmenu', function (e) {
                e.preventDefault();
                showWarning();
            });

            // Disable copy
            document.addEventListener('copy', function (e) {
                e.preventDefault();
                showWarning();
            });

            // Disable cut
            document.addEventListener('cut', function (e) {
                e.preventDefault();
                showWarning();
            });

            // Disable paste on non-form elements
            document.addEventListener('paste', function (e) {
                if (!e.target.matches('input, textarea, [contenteditable]')) {
                    e.preventDefault();
                }
            });

            // Disable drag-to-copy on non-form elements
            document.addEventListener('dragstart', function (e) {
                if (!e.target.matches('input, textarea, img, a')) {
                    e.preventDefault();
                }
            });

            // Disable keyboard shortcuts
            document.addEventListener('keydown', function (e) {
                const key = e.key.toLowerCase();

                // Ctrl / Cmd combinations
                if (e.ctrlKey || e.metaKey) {
                    // Block: C (copy), A (select all), U (view source), S (save), P (print)
                    if (['c', 'a', 'u', 's', 'p'].includes(key)) {
                        e.preventDefault();
                        showWarning();
                        return;
                    }
                }

                // Ctrl + Shift + I / J / C (DevTools)
                if ((e.ctrlKey || e.metaKey) && e.shiftKey && ['i', 'j', 'c'].includes(key)) {
                    e.preventDefault();
                    return;
                }

                // F12 (DevTools)
                if (e.key === 'F12') {
                    e.preventDefault();
                    return;
                }

                // Print Screen
                if (e.key === 'PrintScreen') {
                    e.preventDefault();
                    showWarning();
                    return;
                }
            });

        })();
    </script>

    @await RenderSectionAsync("Scripts", required: false)
