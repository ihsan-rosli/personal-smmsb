# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicitly LF
*.cs        text eol=lf
*.csproj    text eol=lf
*.slnx      text eol=lf
*.sln       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.xml       text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.razor     text eol=lf
*.cshtml    text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf
*.ts        text eol=lf
*.sh        text eol=lf
Dockerfile  text eol=lf

# Binary — no line ending conversion
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.dll       binary
*.exe       binary
*.pdb       binary
*.zip       binary
*.nupkg     binary
